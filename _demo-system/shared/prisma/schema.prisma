  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, username])
  @@index([username, isRead])
  @@index([notificationId])
  @@map("user_notification_status")
}

enum CardStatus {
  UNASSIGNED
  ASSIGNED
  REVOKED
  SUSPENDED
  EXPIRED
}

model AccessCard {
  cardId            String     @id @map("card_id") // ****-****-****-****
  employeeUsername  String?    @map("employee_username")
  guestUsername     String?    @map("guest_username")
  status            CardStatus @default(UNASSIGNED)
  pinHash           String?    @map("pin_hash")
  pinSalt           String?    @map("pin_salt")
  pinCreatedAt      DateTime?  @map("pin_created_at") @db.Timestamptz
  pinLastVerified   DateTime?  @map("pin_last_verified") @db.Timestamptz
  pinFailedAttempts Int        @default(0) @map("pin_failed_attempts")
  pinLockedUntil    DateTime?  @map("pin_locked_until") @db.Timestamptz
  assignedDate      DateTime?  @map("assigned_date") @db.Timestamptz
  assignedBy        String?    @map("assigned_by")
  revokedDate       DateTime?  @map("revoked_date") @db.Timestamptz
  revokedBy         String?    @map("revoked_by")
  lastUsed          DateTime?  @map("last_used") @db.Timestamptz
  useCount          Int        @default(0) @map("use_count")
  zone              Zone       @default(JPN)
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  employee   Employee?    @relation(fields: [employeeUsername], references: [username])
  guest      Guest?       @relation(fields: [guestUsername], references: [username])
  pinHistory PinHistory[]

  @@map("access_cards")
}

model PinHistory {
  id        Int      @id @default(autoincrement())
  cardId    String   @map("card_id")
  pinHash   String   @map("pin_hash")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy String   @map("created_by") // "user" or "admin"

  // Relations
  card AccessCard @relation(fields: [cardId], references: [cardId])

  @@map("pin_history")
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
  FORCE
  ACCESS
  PRINT
  EXPORT
  REQUEST
  APPROVE
  ORDER
  LOCK
  COMPLETE
  CANCEL
  CUT
}

enum PermissionScope {
  ALL
  OWN
  DEPARTMENT
  TEAM
  GROUP
  ZONE
  NONE
  CUSTOM
}

enum AccessType {
  KIOSK
  WEB
  BOTH
}

model Permission {
  id          Int              @id @default(autoincrement())
  code        String           @unique // [action]:[resource]#[scope]
  category    Json? // { ja: string, en: string }
  name        Json // { ja: string, en: string }
  description Json? // { ja: string, en: string }
  action      PermissionAction @default(READ)
  resource    String           @default("*") // * for all resources
  scope       PermissionScope  @default(ALL)
  accessType  AccessType       @default(BOTH) @map("access_type")
  requiresMFA Boolean          @default(false) @map("requires_mfa")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  groupPermissions GroupPermission[]

  @@map("permissions")
}

model GroupPermission {
  id           Int      @id @default(autoincrement())
  groupId      Int      @map("group_id")
  permissionId Int      @map("permission_id")
  grantedBy    String   @map("granted_by")
  zone         Zone     @default(JPN)
  grantedAt    DateTime @default(now()) @map("granted_at") @db.Timestamptz
  isEnabled    Boolean  @default(true) @map("is_enabled")

  // Relations
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([groupId, permissionId])
  @@map("group_permissions")
}

model EmployeeZone {
  id               Int      @id @default(autoincrement())
  employeeUsername String   @map("employee_username")
  zone             Zone
  assignedAt       DateTime @default(now()) @map("assigned_at") @db.Timestamptz
  assignedBy       String?  @map("assigned_by")

  // Relations
  employee Employee @relation(fields: [employeeUsername], references: [username], onDelete: Cascade)

  @@unique([employeeUsername, zone])
  @@index([employeeUsername])
  @@index([zone])
  @@map("employee_zones")
}

// Database view for fast permission lookups
// One record per employee with aggregated group_ids, permission_codes, zones arrays, and employee details
// See: https://www.prisma.io/docs/orm/prisma-schema/data-model/views
view EmployeePermissionsView {
  username        String   @unique
  isEnabled       Boolean  @map("is_enabled")
  displayName     String   @map("display_name")
  department      String?
  title           String?
  zones           String[] @db.Text
  groupIds        Int[]    @map("group_ids") @db.Integer
  permissionCodes String[] @map("permission_codes") @db.Text

  @@map("employee_permissions_view")
}

// Stock management views
// See: https://www.prisma.io/docs/orm/prisma-schema/data-model/views
view StockSummaryView {
  factoryId        Int     @map("factory_id")
  materialId       Int     @map("material_id")
  diameter         Decimal // 直径 (actual diameter, used in 素材コード)
  length           Decimal
  polished         Boolean
  customType       String? @map("custom_type") // Optional custom type for stock classification
  currentQuantity  Int     @map("current_quantity") // Current available stock quantity
  reservedQuantity Int     @map("reserved_quantity") // Quantity reserved for outgoing (orders)
  plannedQuantity  Int     @map("planned_quantity") // Quantity planned for incoming (purchases)
  estimateQuantity Int     @map("estimate_quantity") // Estimated available quantity after planned changes (current + planned - reserved)

  @@map("app_stock_summary_view")
}

view StockPurchaseSummaryView {
  supplierId     Int      @map("supplier_id")
  purchaseDate   DateTime @map("purchase_date") @db.Timestamptz
  totalPurchases Int      @map("total_purchases")
  averagePrice   Decimal  @map("average_price")
  purchaseCounts Int      @map("purchase_counts")

  @@map("app_stock_purchase_summary_view")
}

view MaterialLatestPriceView {
  materialId          Int      @map("material_id")
  diameter            Decimal
  length              Decimal
  polished            Boolean
  customType          String?  @map("custom_type") // Optional custom type for stock classification
  latestPricePerPiece Decimal  @map("latest_price_per_piece")
  latestPricePerUnit  Decimal? @map("latest_price_per_unit")
  latestPurchaseDate  DateTime @map("latest_purchase_date") @db.Timestamptz
  latestPurchaseId    Int      @map("latest_purchase_id")
  latestSupplierId    Int      @map("latest_supplier_id")
  currency            String

  @@map("app_material_latest_price_view")
}

model HRRecord {
  id               Int      @id @default(autoincrement())
  employeeUsername String   @map("employee_username")
  zone             Zone
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  date            DateTime @db.Timestamptz
  wtNormal        Int      @map("wt_normal")
  wtOvertime      Int      @map("wt_overtime")
  wtOvertimeNight Int      @map("wt_overtime_night")
  wtNight         Int      @map("wt_night")
  wtLeaveLate     Int      @map("wt_leave_late")
  pto             Int

  planStart DateTime? @map("plan_start") @db.Timestamptz
  planEnd   DateTime? @map("plan_end") @db.Timestamptz

  recordStart DateTime[] @map("record_starts") @db.Timestamptz
  recordEnd   DateTime[] @map("record_ends") @db.Timestamptz

  restStart DateTime[] @map("rest_starts") @db.Timestamptz
  restEnd   DateTime[] @map("rest_ends") @db.Timestamptz

  employee Employee @relation(fields: [employeeUsername], references: [username], onDelete: Cascade)

  @@index([employeeUsername, zone, date])
  @@map("hr_records")
}

view HRSummaryView {
  employeeUsername String   @map("employee_username")
  zone             Zone
  month            DateTime @db.Timestamptz

  wtNormal        Int @map("wt_normal")
  wtOvertime      Int @map("wt_overtime")
  wtOvertimeNight Int @map("wt_overtime_night")
  wtNight         Int @map("wt_night")
  wtLeaveLate     Int @map("wt_leave_late")
  pto             Int @map("pto")

  @@map("hr_summary_view")
}
