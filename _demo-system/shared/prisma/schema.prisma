}

model PriceListTier {
  id          Int      @id @default(autoincrement())
  priceListId Int      @map("price_list_id")
  minQuantity Int      @map("min_quantity") // inclusive
  maxQuantity Int?     @map("max_quantity") // inclusive; null = no upper bound (e.g. 50-)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  currency    Currency @default(JPY)

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@index([priceListId])
  @@map("app_price_list_tiers")
}

// Delivery addresses grouped by customer (purchaser or end user)
model Address {
  id           Int      @id @default(autoincrement())
  customerId   Int      @map("customer_id")
  label        String? // e.g. "本社", "工場A"
  postalCode   String?  @map("postal_code")
  prefecture   String?
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  phone        String?
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  customer                      Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shippingInstructionsTo        ShippingInstruction[] @relation("ShippingInstructionToAddress")
  shippingInstructionsInvoiceTo ShippingInstruction[] @relation("ShippingInstructionInvoiceToAddress")

  @@index([customerId])
  @@map("app_addresses")
}

// Delivery 指示書: multiple per 受注.
// 在庫 (STOCK): from factory → to factory.
// 通常配送 (NORMAL_DELIVERY): from factory → to address.
// 直送 (USER_DIRECT): from factory → to address (end user). 納品書送付先 = invoiceToAddressId. 配送伝票 only with item to end user.
model ShippingInstruction {
  id                 Int                       @id @default(autoincrement())
  orderId            Int                       @map("order_id")
  type               ShippingInstructionType
  status             ShippingInstructionStatus @default(PLANNED) @map("status")
  plannedQuantity    Int?                      @map("planned_quantity")
  resultQuantity     Int?                      @map("result_quantity")
  fromFactoryId      Int?                      @map("from_factory_id") // 出発: 工場
  toFactoryId        Int?                      @map("to_factory_id") // 在庫: 宛先工場
  toAddressId        Int?                      @map("to_address_id") // 通常配送・直送: 宛先住所（直送はエンドユーザー宛）
  invoiceToAddressId Int?                      @map("invoice_to_address_id") // 直送のみ: 納品書送付先
  notes              String?                   @db.Text
  createdAt          DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromFactory      Factory? @relation("ShippingInstructionFromFactory", fields: [fromFactoryId], references: [id], onDelete: SetNull)
  toFactory        Factory? @relation("ShippingInstructionToFactory", fields: [toFactoryId], references: [id], onDelete: SetNull)
  toAddress        Address? @relation("ShippingInstructionToAddress", fields: [toAddressId], references: [id], onDelete: SetNull)
  invoiceToAddress Address? @relation("ShippingInstructionInvoiceToAddress", fields: [invoiceToAddressId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([fromFactoryId])
  @@index([toFactoryId])
  @@index([toAddressId])
  @@index([invoiceToAddressId])
  @@map("app_shipping_instructions")
}

model Supplier {
