  name         String      @unique // Group identifier (e.g., "Domain Users", "app_managers")
  displayName  String?     @map("display_name") // Friendly display name
  description  String?
  source       GroupSource @default(APP)
  adGroupDn    String?     @map("ad_group_dn") // AD Distinguished Name (for AD groups only)
