generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["fullTextSearchPostgres", "views"]
}

datasource db {
  provider = "postgresql"
}

// auth related models
// User model: Stores authenticated users
// - Image is populated from dev-users.json on each login
// - Email and name are stored in Employee table, not here
// - Updated automatically when user authenticates via LDAP or dev authentication
model User {
  id        String    @id @default(cuid())
  username  String    @unique
  image     String? // Populated from dev-users.json
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  sessions  Session[]

  @@map("auth_users")
}

// Session model: Stores active user sessions in database (migrated from Redis)
// - Token is cryptographically secure (generated with crypto.randomBytes)
// - Sessions are automatically cleaned up when expired
// - TTL is configurable via SESSION_TTL environment variable (default: 8 hours)
// - IP address and user agent are tracked for security/audit purposes
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  token     String   @unique // Cryptographically secure session token
  ipAddress String?  @map("ip_address") // Optional IP tracking
  userAgent String?  @map("user_agent") // Optional user agent tracking
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

enum Zone {
  JPN
  CHN
  SEA
  EUR
}

// app related models
enum OrderStatus {
  DRAFT
  PENDING
  ORDERED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum Currency {
  JPY
  USD
  EUR
  CNY
  THB
}

enum ShippingInstructionType {
  USER_DIRECT // ユーザー直送
  NORMAL_DELIVERY // 通常配送
  STOCK // 在庫
}

enum ShippingInstructionStatus {
  PLANNED // 計画済み
  IN_PROGRESS // 配送中
  COMPLETED // 完了
}

enum PurchaseStatus {
  DRAFT // Initial creation, editable
  REQUESTED // Submitted for approval
  APPROVED // Approved, ready to order
  ORDERED // Order placed with supplier (adds to plannedQuantity)
  COMPLETED // Delivered, stock increased (moves from plannedQuantity to availableQuantity)
  CANCELLED // Cancelled at any stage
}

model OrderReceipt {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  customerId       Int      @map("customer_id")
  receivedAt       DateTime @map("received_at") @db.Timestamptz
  employeeUsername String   @map("employee_username")
  orderDate        DateTime @map("order_date") @db.Timestamptz
  deliveryDate     DateTime @map("delivery_date") @db.Timestamptz
  totalAmount      Decimal? @default(0) @map("total_amount") // 注文受取書合計（受注書合計と一致しない場合あり）
  notes            String?  @db.Text
  externalDocRef   String?  @map("external_doc_ref") // e.g. 注文書 FAX/PDF identifier
  isDeleted        Boolean  @default(false) @map("is_deleted")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  customer Customer @relation(fields: [customerId], references: [id])
  employee Employee @relation(fields: [employeeUsername], references: [username])
  orders   Order[]

  @@index([customerId])
  @@index([receivedAt])
  @@index([totalAmount])
  @@map("app_order_receipts")
}

model Order {
  id              Int         @id @default(autoincrement())
  code            String      @unique
  status          OrderStatus @default(DRAFT)
  zone            Zone        @default(JPN)
  orderReceiptId  Int         @map("order_receipt_id")
  productId       Int         @map("product_id")
  orderedQuantity Int         @default(0) @map("ordered_quantity") // 受注数量
  totalQuantity   Int         @default(0) @map("total_quantity") // 総数量（>= ordered、余剰在庫含む場合あり）
  currency        Currency    @default(JPY)
  unitPrice       Decimal?    @default(0) @map("unit_price") // 単価（totalAmount と一致しない場合あり）
  totalAmount     Decimal     @default(0) @map("total_amount") // 受注書行の合計金額
  notes           String?

  // Status management
  statusChangedAt DateTime? @map("status_changed_at") @db.Timestamptz

  // Cancellation
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz
  cancelledBy        String?   @map("cancelled_by")
  cancellationReason String?   @map("cancellation_reason") @db.Text

  // Archival
  archivedAt DateTime? @map("archived_at") @db.Timestamptz
  archivedBy String?   @map("archived_by")

  // Completion
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  // Optional end user (customer_id). Purchaser is from OrderReceipt.customerId.
  endUserId Int? @map("end_user_id")

  isDeleted Boolean @default(false) @map("is_deleted")

  orderReceipt OrderReceipt @relation(fields: [orderReceiptId], references: [id], onDelete: Restrict)
  product      Product      @relation(fields: [productId], references: [id])
  endUser      Customer?    @relation("OrderEndUser", fields: [endUserId], references: [id], onDelete: SetNull)

  // processPlans           ProcessPlan[]
  // processRecords         ProcessRecord[]
  manufacturingWorkflows ManufacturingWorkflow[]
  stockReservations      StockReservation[]
  shippingInstructions   ShippingInstruction[]

  @@index([orderReceiptId])
  @@index([orderReceiptId, totalAmount])
  @@index([endUserId])
  @@index([status])
  @@map("app_orders")
}

model ManufacturingWorkflow {
  id              Int      @id @default(autoincrement())
  orderId         Int      @map("order_id")
  name            String?
  displayOrder    Int      @default(0) @map("display_order")
  plannedQuantity Int?     @map("planned_quantity") // Plan quantity for this workflow; sum over all workflows = order.totalQuantity
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  order Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  plans ProcessPlan[]

  // Split/merge DAG links
  outgoingLinks WorkflowLink[] @relation("OutgoingLinks")
  incomingLinks WorkflowLink[] @relation("IncomingLinks")

  @@index([orderId])
  @@map("app_manufacturing_workflows")
}

// Links between workflows for split/merge DAG.
// Each link routes a quantity of items from a source workflow to a target workflow.
model WorkflowLink {
  id               Int @id @default(autoincrement())
  sourceWorkflowId Int @map("source_workflow_id")
  targetWorkflowId Int @map("target_workflow_id")

  // Which plan in the source workflow the split occurs after.
  // If null, link is from the end (last plan) of the source workflow.
  splitAfterPlanId Int? @map("split_after_plan_id")

  // How many items flow through this link
  routedQuantity Int @default(0) @map("routed_quantity")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sourceWorkflow ManufacturingWorkflow @relation("OutgoingLinks", fields: [sourceWorkflowId], references: [id], onDelete: Cascade)
  targetWorkflow ManufacturingWorkflow @relation("IncomingLinks", fields: [targetWorkflowId], references: [id], onDelete: Cascade)
  splitAfterPlan ProcessPlan?          @relation("SplitLinks", fields: [splitAfterPlanId], references: [id], onDelete: SetNull)

  @@unique([sourceWorkflowId, targetWorkflowId])
  @@index([sourceWorkflowId])
  @@index([targetWorkflowId])
  @@map("app_workflow_links")
}

model Product {
  id            Int     @id @default(autoincrement())
  code          String
  version       Int
  name          String? // 製品名
  description   String? @db.Text // 説明 (line breaks)
  isParent      Boolean @default(false) @map("is_parent")
  inheritedFrom Int?    @map("inherited_from")

  materialId Int      @map("material_id")
  material   Material @relation(fields: [materialId], references: [id])

  shape                   String? // 製品形状
  classification          String? // 製品分類
  materialNominalDiameter Int?    @map("material_nominal_diameter") // 素材呼び径 (0.1 mm)
  materialLength          Int?    @map("material_length") // 素材全長 (0.1 mm)
  bladeCount              Int?    @map("blade_count") // 刃数
  coatingType             String? @map("coating_type") // コーティングの種類
  specMemo                String? @map("spec_memo") @db.Text // 製品仕様メモ (rich text)

  threeDFilePath String? @map("3d_file_path")

  isDeleted Boolean @default(false) @map("is_deleted")

  inheritedFromProduct Product?  @relation("ProductInheritance", fields: [inheritedFrom], references: [id])
  inheritedByProducts  Product[] @relation("ProductInheritance")

  orders             Order[]
  machinePrograms    MachineProgram[]
  inspectionPrograms InspectionProgram[]
  priceLists         PriceList[]

  @@unique([code, version], name: "code_version")
  @@map("app_products")
}

model Material {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  description String?
  notes       String?

  // Codes from material-grade (used in 材種コード): A,B,C,D / 1,2,3 / A,B,0 / 1,2,...
  mfrCode      String? @map("mfr_code") // Manufacturer key A,B,C,D
  mfrGradeCode Int?    @map("mfr_grade_code") // Grade number 1,2,3
  shapeCode    String? @map("shape_code") // Shape key A,B,0
  typeCode     Int?    @map("type_code") // Type number 1,2,... or from API for shape 0 (autoincrement)

  isDeleted Boolean @default(false) @map("is_deleted")

  products           Product[]
  stocks             Stock[]
  stockReservations  StockReservation[]
  stockPurchaseItems StockPurchaseItem[]
  stockTransactions  StockTransaction[]

  @@unique([mfrCode, mfrGradeCode, shapeCode, typeCode], name: "material_grade_code")
  @@map("app_materials")
}

enum StockReservationStatus {
  RESERVED
  LOCKED
  COMPLETED
  CANCELLED
}

enum StockTransactionType {
  CUT
  USE
  DAMAGED
  DISCARD
  DEFECTIVE
  STOCK_TAKE
  OVERRIDE
  MOVE
  PURCHASE
}

model StockPurchase {
  id                  Int      @id @default(autoincrement())
  supplierId          Int      @map("supplier_id")
  purchaseDate        DateTime @map("purchase_date") @db.Timestamptz
  invoiceNumber       String?  @map("invoice_number")
  purchaseOrderNumber String?  @map("purchase_order_number")
  employeeUsername    String   @map("employee_username") // Employee responsible for this purchase (required for permission checks)

  totalAmount Decimal  @default(0) @map("total_amount")
  currency    Currency @default(JPY)

  notes String? @db.Text

  status             PurchaseStatus @default(DRAFT)
  statusChangedAt    DateTime?      @map("status_changed_at") @db.Timestamptz
  requestedAt        DateTime?      @map("requested_at") @db.Timestamptz
  requestedBy        String?        @map("requested_by")
  approvedAt         DateTime?      @map("approved_at") @db.Timestamptz
  approvedBy         String?        @map("approved_by")
  orderedAt          DateTime?      @map("ordered_at") @db.Timestamptz
  orderedBy          String?        @map("ordered_by")
  completedAt        DateTime?      @map("completed_at") @db.Timestamptz
  completedBy        String?        @map("completed_by")
  cancelledAt        DateTime?      @map("cancelled_at") @db.Timestamptz
  cancelledBy        String?        @map("cancelled_by")
  cancellationReason String?        @map("cancellation_reason") @db.Text
  history            Json? // Array of { type: string, user: string, timestamp: string, action?: string, notes?: string }

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  supplier          Supplier                @relation(fields: [supplierId], references: [id])
  employee          Employee                @relation(fields: [employeeUsername], references: [username], onDelete: Restrict)
  purchaseItems     StockPurchaseItem[]
  stockReservations StockReservation[]
  approvers         StockPurchaseApprover[]

  @@index([supplierId])
  @@index([purchaseDate])
  @@index([status])
  @@index([employeeUsername])
  @@map("app_stock_purchases")
}

model StockPurchaseItem {
  id                 Int      @id @default(autoincrement())
  stockPurchaseId    Int      @map("stock_purchase_id")
  materialId         Int      @map("material_id")
  factoryId          Int      @map("factory_id")
  diameter           Decimal // 直径 (actual diameter, used in 素材コード)
  nominalDiameter    Decimal? @map("nominal_diameter") // 呼び径 (nominal/call diameter, for display)
  length             Decimal
  polished           Boolean  @default(false)
  customType         String   @default("-") @map("custom_type") // Custom type for stock classification (required for unique constraint)
  quantity           Int // Number of pieces
  pricePerPiece      Decimal  @map("price_per_piece")
  pricePerUnit       Decimal? @map("price_per_unit") // Price per 1000mm
  currency           Currency @default(JPY)
  stockTransactionId Int?     @unique @map("stock_transaction_id") // Link to StockTransaction when stock is increased
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  stockPurchase    StockPurchase     @relation(fields: [stockPurchaseId], references: [id], onDelete: Cascade)
  material         Material          @relation(fields: [materialId], references: [id])
  factory          Factory           @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  stockTransaction StockTransaction? @relation(fields: [stockTransactionId], references: [id], onDelete: SetNull)

  @@index([stockPurchaseId])
  @@index([materialId, diameter, length, polished, customType])
  @@index([factoryId])
  @@index([stockTransactionId])
  @@map("app_stock_purchase_items")
}

model StockPurchaseApprover {
  id               Int      @id @default(autoincrement())
  stockPurchaseId  Int      @map("stock_purchase_id")
  groupId          Int?     @map("group_id")
  employeeUsername String?  @map("employee_username")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  stockPurchase StockPurchase @relation(fields: [stockPurchaseId], references: [id], onDelete: Cascade)
  group         Group?        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  employee      Employee?     @relation(fields: [employeeUsername], references: [username], onDelete: Cascade)

  @@unique([stockPurchaseId, groupId, employeeUsername])
  @@index([stockPurchaseId])
  @@index([groupId])
  @@index([employeeUsername])
  @@map("app_stock_purchase_approvers")
}

model Stock {
  id                Int      @id @default(autoincrement())
  materialId        Int      @map("material_id")
  diameter          Decimal // 直径 (actual diameter, used in 素材コード)
  nominalDiameter   Decimal? @map("nominal_diameter") // 呼び径 (nominal/call diameter, for display)
  length            Decimal
  polished          Boolean  @default(false)
  customType        String   @default("-") @map("custom_type") // Custom type for stock classification (required for unique constraint)
  factoryId         Int      @map("factory_id")
  availableQuantity Int      @default(0) @map("available_quantity") // Number of pieces
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  factory  Factory  @relation(fields: [factoryId], references: [id], onDelete: Restrict)

  @@unique([materialId, diameter, length, polished, customType, factoryId])
  @@index([materialId, diameter, length, polished, customType, factoryId])
  @@index([factoryId])
  @@map("app_stocks")
}

model StockReservation {
  id              Int                    @id @default(autoincrement())
  materialId      Int                    @map("material_id")
  diameter        Decimal
  length          Decimal
  polished        Boolean                @default(false)
  customType      String                 @default("-") @map("custom_type") // Custom type for stock classification (required for index)
  factoryId       Int?                   @map("factory_id")
  direction       Boolean                @default(false) // true = increase, false = decrease
  quantity        Int // Number of pieces
  // Outgoing reservation: links to an Order (stock is planned to be consumed)
  orderId         Int?                   @map("order_id")
  // Incoming reservation: links to a StockPurchase (stock is planned to arrive)
  stockPurchaseId Int?                   @map("stock_purchase_id")
  status          StockReservationStatus @default(RESERVED)
  reservedAt      DateTime               @default(now()) @map("reserved_at") @db.Timestamptz
  lockedAt        DateTime?              @map("locked_at") @db.Timestamptz
  completedAt     DateTime?              @map("completed_at") @db.Timestamptz
  cancelledAt     DateTime?              @map("cancelled_at") @db.Timestamptz
  notes           String?                @db.Text
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  material      Material           @relation(fields: [materialId], references: [id], onDelete: Cascade)
  factory       Factory?           @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  order         Order?             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stockPurchase StockPurchase?     @relation(fields: [stockPurchaseId], references: [id], onDelete: Cascade)
  transactions  StockTransaction[]

  @@index([materialId, diameter, length, polished, customType, factoryId, status])
  @@index([factoryId])
  @@index([orderId, status])
  @@index([stockPurchaseId, status])
  @@map("app_stock_reservations")
}

model StockTransaction {
  id                  Int                  @id @default(autoincrement())
  materialId          Int                  @map("material_id")
  diameter            Decimal
  length              Decimal
  polished            Boolean              @default(false)
  customType          String               @default("-") @map("custom_type") // Custom type for stock classification (required for index)
  factoryId           Int?                 @map("factory_id") // Factory for this transaction
  usageLocation       String?              @map("usage_location") // detail location
  linkedTransactionId Int?                 @map("linked_transaction_id") // Link to related transaction. REQUIRED for MOVE and CUT transactions (both transactions must be linked)
  transactionType     StockTransactionType @map("transaction_type")
  direction           Boolean              @default(false) // true = increase, false = decrease
  quantity            Int? // Transaction quantity (null for STOCK_TAKE and OVERRIDE)
  quantityBefore      Int                  @map("quantity_before") // Stock quantity before transaction (always recorded)
  quantityAfter       Int                  @map("quantity_after") // Stock quantity after transaction (always recorded)
  orderId             Int?                 @map("order_id")
  reservationId       Int?                 @map("reservation_id")
  employeeUsername    String?              @map("employee_username")
  notes               String?              @db.Text
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz

  material           Material           @relation(fields: [materialId], references: [id], onDelete: Cascade)
  factory            Factory?           @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  linkedTransaction  StockTransaction?  @relation("LinkedTransactions", fields: [linkedTransactionId], references: [id], onDelete: SetNull)
  linkedTransactions StockTransaction[] @relation("LinkedTransactions")
  reservation        StockReservation?  @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  employee           Employee?          @relation(fields: [employeeUsername], references: [username])
  purchaseItem       StockPurchaseItem? @relation

  // Business Rule: MOVE and CUT transactions MUST have linkedTransactionId set
  // - MOVE: Creates two transactions (source decrease, target increase), both must be linked
  // - CUT: Creates two transactions (source decrease, target increase), both must be linked
  // This is enforced at the application level since Prisma doesn't support conditional constraints
  // The API validates that both transactions have linkedTransactionId before completing

  @@index([materialId, diameter, length, polished, customType, transactionType])
  @@index([transactionType, createdAt])
  @@index([reservationId])
  @@index([factoryId])
  @@index([linkedTransactionId])
  @@map("app_stock_transactions")
}

enum ProcessPlanStatus {
  DRAFT // Planning phase
  READY // Can start work
  COMPLETED // All work done
  CANCELLED // Process cancelled
}

enum ProcessRecordType {
  IN_PROGRESS // Currently working
  COMPLETED // Session finished
  CANCELLED // Session cancelled
}

// Special role: initial (exactly one per workflow) or final (none or 出荷前検査).
enum ProcessTemplateSpecialKind {
  NONE // Regular step
  INITIAL // Initial process; exactly one assignable per workflow (素材出し, 半製品出し, 素材受渡し, 製品受渡し)
  FINAL // Final process; none or 出荷前検査
}

// Workflow step kind (1.6 start/end, 1.7 delivery). Valid start: first 4; end: SHIPMENT; PRE_SHIPMENT_INSPECTION is skippable.
enum ProcessTemplateStepKind {
  MATERIAL_FROM_STOCK // 素材出し（在庫から）
  SEMI_FROM_STOCK // 半製品出し（在庫から）
  MATERIAL_HANDOVER // 素材受渡し（受注元から）
  PRODUCT_HANDOVER // 製品受渡し（受注元から）
  PROCESSING // Generic processing
  PRE_SHIPMENT_INSPECTION // 出荷前検査 (skippable)
  SHIPMENT // 出荷 (final step)
  INTER_FACTORY_DELIVERY // 工場間受け渡し (auto-inserted between different factories)
}

model ProcessTemplate {
  id                 Int     @id @default(autoincrement())
  name               Json // { ja: string, en: string }
  description        Json? // { ja: string, en: string }
  displayOrder       Int     @default(0) @map("display_order")
  onStartLogicKey    String? @map("on_start_logic_key")
  onCompleteLogicKey String? @map("on_complete_logic_key")
  customViewLogicKey String? @map("custom_view_logic_key")
  hideButton         Boolean @default(false) @map("hide_button")

  // Workflow structure (1.6): step kind and whether 出荷前検査 is skippable for this template
  stepKind              ProcessTemplateStepKind    @default(PROCESSING) @map("step_kind")
  isSkippableInspection Boolean                    @default(false) @map("is_skippable_inspection")
  // Initial step (exactly one per workflow) or final step (none or 出荷前検査)
  specialKind           ProcessTemplateSpecialKind @default(NONE) @map("is_special")

  // required_exist: template IDs that must be present in the workflow when this template is used (使用依存)
  requiredExistTemplateIds  Int[] @default([]) @map("required_exist_template_ids")
  // required_before: (1) Plan: those templates must exist in the workflow and be ordered before this step. (2) Execution: when present in the workflow, they must be completed before this step can start (実行依存)
  requiredBeforeTemplateIds Int[] @default([]) @map("required_before_template_ids")
  // Warning shown when requirements are not fulfilled. { ja: string, en: string }
  requirementsWarning       Json? @map("requirements_warning")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  plans ProcessPlan[]
  // records ProcessRecord[]

  @@index([displayOrder])
  @@index([stepKind])
  @@index([specialKind])
  @@map("app_process_templates")
}

model ProcessPlan {
  id         Int  @id @default(autoincrement())
  // orderId     Int  @map("order_id")
  workflowId Int? @map("workflow_id") // which manufacturing workflow this step belongs to
  templateId Int  @map("template_id")
  sequence   Int  @default(0)
  factoryId  Int? @map("factory_id")

  // For INTER_FACTORY_DELIVERY steps only (1.7): from/to factory
  fromFactoryId Int? @map("from_factory_id")
  toFactoryId   Int? @map("to_factory_id")

  // Planning details
  plannedAt      DateTime? @map("planned_at") @db.Timestamptz
  assignedTo     String?   @map("assigned_to")
  estimatedHours Float?    @map("estimated_hours")
  notes          String?   @db.Text

  // 出荷前検査 skip: when template is PRE_SHIPMENT_INSPECTION, true = skip this step (1.6)
  skipInspection Boolean @default(false) @map("skip_inspection")

  // Simplified status (no IN_PROGRESS, no PAUSED)
  status          ProcessPlanStatus @default(DRAFT)
  statusChangedAt DateTime?         @map("status_changed_at") @db.Timestamptz

  // Completion
  markedComplete   Boolean   @default(false) @map("marked_complete")
  markedCompleteAt DateTime? @map("marked_complete_at") @db.Timestamptz
  markedCompleteBy String?   @map("marked_complete_by")

  // Item counts: input from previous step, success passed to next, defect handling
  // First step: inputQuantity can be set from order.totalQuantity or manually
  // Next steps: input = previous step's outputSuccessQuantity (computed or copied)
  inputQuantity            Int? @map("input_quantity") // Count received from previous step
  outputSuccessQuantity    Int? @map("output_success_quantity") // Success items passed to next step
  outputDefectSemiFinished Int? @map("output_defect_semi_finished") // 半製品 stock
  outputDefectScrap        Int? @map("output_defect_scrap") // Thrown away
  outputDefectRework       Int? @map("output_defect_rework") // Split / additional step to complete

  // Cancellation
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz
  cancelledBy        String?   @map("cancelled_by")
  cancellationReason String?   @map("cancellation_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  // order        Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  workflow         ManufacturingWorkflow? @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  template         ProcessTemplate        @relation(fields: [templateId], references: [id])
  factory          Factory?               @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  fromFactory      Factory?               @relation("ProcessPlanFromFactory", fields: [fromFactoryId], references: [id], onDelete: SetNull)
  toFactory        Factory?               @relation("ProcessPlanToFactory", fields: [toFactoryId], references: [id], onDelete: SetNull)
  assignedEmployee Employee?              @relation("ProcessPlanAssigned", fields: [assignedTo], references: [username])
  records          ProcessRecord[]
  splitLinks       WorkflowLink[]         @relation("SplitLinks") // DAG links that split after this plan

  // Multiple plans per (orderId, templateId) allowed for INTER_FACTORY_DELIVERY (1.7)
  @@index([templateId])
  // @@index([orderId])
  @@index([workflowId])
  @@index([status])
  @@index([factoryId])
  @@map("app_process_plans")
}

model ProcessRecord {
  id     Int @id @default(autoincrement())
  planId Int @map("plan_id")
  // templateId Int @map("template_id")
  // orderId    Int @map("order_id")

  // Record type and time tracking
  // Note: endAt can be filled while type is IN_PROGRESS (paused state)
  // - Active session: type = IN_PROGRESS, endAt = NULL
  // - Paused session: type = IN_PROGRESS, endAt = filled
  // - Completed session: type = COMPLETED, endAt = filled
  type    ProcessRecordType @default(IN_PROGRESS)
  startAt DateTime          @map("start_at") @db.Timestamptz
  endAt   DateTime?         @map("end_at") @db.Timestamptz

  // Session details
  achievedBy         String  @map("achieved_by")
  notes              String? @db.Text
  logicResult        Json?   @map("logic_result")
  cancellationReason String? @map("cancellation_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  plan             ProcessPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  // template         ProcessTemplate @relation(fields: [templateId], references: [id])
  // orderRelation    Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  achievedEmployee Employee    @relation("ProcessRecordAchieved", fields: [achievedBy], references: [username])

  @@index([planId])
  // @@index([orderId])
  @@index([type])
  @@map("app_process_records")
}

