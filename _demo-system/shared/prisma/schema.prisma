// Price list per customer and item (invoice / 見積書); tiers define unit price by quantity range
model PriceList {
  id         Int       @id @default(autoincrement())
  customerId Int       @map("customer_id")
  productId  Int       @map("product_id")
  currency   Currency  @default(JPY)
  validFrom  DateTime? @map("valid_from") @db.Timestamptz // date from which this price list is effective
  isDeleted  Boolean   @default(false) @map("is_deleted")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product  Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  tiers    PriceListTier[]

  @@unique([customerId, productId], name: "price_list_customer_product")
  @@index([customerId])
  @@index([productId])
  @@index([isDeleted])
  @@index([validFrom])
