diff --git a/src/list_columns.c b/src/list_columns.c
index 2eef63b..6422c83 100644
--- a/src/list_columns.c
+++ b/src/list_columns.c
@@ -33,6 +33,28 @@ typedef struct fmp_list_columns_ctx_s {
     fmp_column_array_t *array;
 } fmp_list_columns_ctx_t;
 
+/* Ensure a column slot exists for this index, with a synthesized fallback name.
+ * Used for the per-column metadata entry (ref_simple==2), which is present for
+ * every column even when the real name is not a decodable string (e.g. number
+ * and calculation fields). A real name, when found, overrides via handle_column. */
+static void ensure_column(size_t column_index, fmp_list_columns_ctx_t *ctx) {
+    fmp_column_array_t *array = ctx->array;
+    if (column_index == 0)
+        return;
+    if (column_index > array->count) {
+        size_t old_num_columns = array->count;
+        array->count = column_index;
+        array->columns = realloc(array->columns, array->count * sizeof(fmp_column_t));
+        memset(&array->columns[old_num_columns], 0, (column_index - old_num_columns) * sizeof(fmp_column_t));
+    }
+    fmp_column_t *current_column = array->columns + column_index - 1;
+    if (current_column->index == 0) {
+        snprintf(current_column->utf8_name, sizeof(current_column->utf8_name),
+                "col%zu", column_index);
+        current_column->index = column_index;
+    }
+}
+
 static chunk_status_t handle_column(size_t column_index, fmp_data_t *name, fmp_list_columns_ctx_t *ctx) {
     fmp_column_array_t *array = ctx->array;
     if (column_index > array->count) {
@@ -86,12 +108,23 @@ static chunk_status_t handle_chunk_list_columns_v7(fmp_chunk_t *chunk, fmp_list_
     if (chunk->type != FMP_CHUNK_FIELD_REF_SIMPLE)
         return CHUNK_NEXT;
 
-    if (table_path_match_start2(chunk, 3, 3, 5)) {
-        fmp_data_t *column_path = chunk->path[chunk->path_level-1];
-        size_t column_index = path_value(chunk, column_path);
-        if (chunk->ref_simple == 16) {
-            handle_column(column_index, &chunk->data, ctx);
-        }
+    /* CKK / FileMaker 7 layout. Every column has a metadata entry at
+     *   [tid].[3].[5].[col]  ref_simple == 2   -> register the column index
+     * and the (string) name nested one level deeper at
+     *   [tid].[3].[5].[col].[16]  ref_simple == 1  -> set the real name.
+     * The integer placeholders some fields carry at ref_simple==1 are <=4 bytes,
+     * so a length guard keeps the synthesized "colN" fallback for those. */
+    if (table_path_match_start2(chunk, 3, 3, 5) && chunk->ref_simple == 2) {
+        size_t column_index = path_value(chunk, chunk->path[chunk->path_level-1]);
+        ensure_column(column_index, ctx);
+        return CHUNK_NEXT;
+    }
+    if (chunk->path_level >= 5 &&
+            path_is(chunk, chunk->path[1], 3) && path_is(chunk, chunk->path[2], 5) &&
+            path_is(chunk, chunk->path[4], 16) && chunk->ref_simple == 1 &&
+            chunk->data.len > 4) {
+        size_t column_index = path_value(chunk, chunk->path[3]);
+        handle_column(column_index, &chunk->data, ctx);
     }
     return CHUNK_NEXT;
 }
