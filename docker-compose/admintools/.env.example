# Postgres password for the admintools app DB.
DB_PASSWORD=change-me

# Sakura RS control-panel login (used only by the "Sync" action):
#   SAKURA_ID = ドメイン名 or a rental-server email address
#   SAKURA_PW = its password
SAKURA_ID=
SAKURA_PW=

# API key external systems must send as the X-API-Key header. Empty = API disabled.
ADMINTOOLS_API_KEY=
