# LDAP/AD credentials for Open WebUI login are centralized in the vpn-ldap stack
# and pulled in via env_file (../vpn-ldap/ldap.env). See docker-compose/vpn-ldap.

# "Chat with the labor data" Open WebUI tool (tools/metabase_labor.py).
# It queries the read-only labor data source through Metabase's API.
#   METABASE_URL     — Metabase base URL reachable from the open-webui container
#   METABASE_DB_ID   — Metabase database id of the labor source (read-only role)
#   METABASE_API_KEY — Metabase API key scoped to the "AI Labor RO" group
METABASE_URL=http://192.168.50.15:3003
METABASE_DB_ID=2
METABASE_API_KEY=
