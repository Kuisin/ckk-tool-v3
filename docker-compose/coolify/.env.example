# Coolify instance env — canonical copy lives at /data/coolify/source/.env on the
# server (server-only, never in git). ~/stacks/coolify/.env is a symlink to it.
#
# Generate secrets with:
#   APP_ID:            openssl rand -hex 16
#   APP_KEY:           echo "base64:$(openssl rand -base64 32)"
#   DB_PASSWORD:       openssl rand -base64 24
#   REDIS_PASSWORD:    openssl rand -base64 24
#   PUSHER_APP_ID:     openssl rand -hex 16
#   PUSHER_APP_KEY:    openssl rand -hex 16
#   PUSHER_APP_SECRET: openssl rand -hex 16

APP_ID=
APP_NAME=Coolify
APP_KEY=

DB_USERNAME=coolify
DB_PASSWORD=
DB_DATABASE=coolify

REDIS_PASSWORD=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=

# First-boot root user (read once on a fresh DB)
ROOT_USERNAME=
ROOT_USER_EMAIL=
ROOT_USER_PASSWORD=

# Keep the instance on the pinned image; upgrade = bump tags in docker-compose.yml
AUTOUPDATE=false

REGISTRY_URL=ghcr.io
