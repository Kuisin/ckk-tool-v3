# Directory where Dockge stores/manages compose stacks. Must be writable by the
# deploying user and is bind-mounted at the identical path inside the container.
#
#   /opt/stacks                  # Dockge default (needs root/sudo to create)
#   /home/<user>/stacks          # home-dir alternative (no sudo) — used on docker-mac-pro
DOCKGE_STACKS_DIR=/home/kaiseisawada/stacks

# Interactive web terminal (host shell) in the Dockge UI. Convenient, but grants
# a root-capable host shell to anyone who can reach the UI — keep the UI on a
# trusted LAN only. Set to true to enable.
DOCKGE_ENABLE_CONSOLE=true
