# Upstream authenticated SMTP that actually delivers the mail.
# Examples:
#   SendGrid:  RELAYHOST=[smtp.sendgrid.net]:587  USERNAME=apikey  PASSWORD=<api key>
#   Mailgun:   RELAYHOST=[smtp.mailgun.org]:587   USERNAME=postmaster@... PASSWORD=<smtp pw>
#   Amazon SES:RELAYHOST=[email-smtp.<region>.amazonaws.com]:587 USERNAME=<smtp user> PASSWORD=<smtp pw>
#   Google WS: RELAYHOST=[smtp.gmail.com]:587      USERNAME=notification@ckk-tool.co.jp PASSWORD=<app password>
#   M365:      RELAYHOST=[smtp.office365.com]:587   USERNAME=notification@ckk-tool.co.jp PASSWORD=<password>
RELAYHOST=
RELAYHOST_USERNAME=
RELAYHOST_PASSWORD=

# Generate a DKIM key in the relay (publish the public key in Cloudflare DNS).
# Set to false if the upstream provider signs DKIM for you.
DKIM_AUTOGENERATE=true
