# Outbound relay through Sakura Rental Server — the host where the
# no-reply@ckk-tool.co.jp mailbox lives (managed via secure.sakura.ad.jp).
# Submission endpoint: ckk-tool.sakura.ne.jp:587 (STARTTLS). Auth with the full
# email address as the username.
RELAYHOST=[ckk-tool.sakura.ne.jp]:587
RELAYHOST_USERNAME=no-reply@ckk-tool.co.jp
RELAYHOST_PASSWORD=

# NOTE: the domain SPF (v=spf1 include:spf.secure.ne.jp -all) does NOT yet cover
# Sakura's outbound IPs — add include:_spf.sakura.ne.jp so authenticated sends via
# Sakura pass SPF. Sakura applies the domain's DKIM on authenticated send, so the
# relay must NOT sign its own DKIM.
DKIM_AUTOGENERATE=false
