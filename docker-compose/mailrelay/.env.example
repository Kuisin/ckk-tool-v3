# Outbound relay through onamae.com's mail host (ckk-tool.co.jp's own mail server).
# Submission endpoint confirmed open: ak115.secure.ne.jp:587 (STARTTLS).
RELAYHOST=[ak115.secure.ne.jp]:587
RELAYHOST_USERNAME=notification@ckk-tool.co.jp
RELAYHOST_PASSWORD=

# onamae/secure.ne.jp applies SPF/DKIM for the domain on authenticated send,
# so the relay must NOT sign its own DKIM.
DKIM_AUTOGENERATE=false
