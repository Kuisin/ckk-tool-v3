# Metabase application-DB password (Postgres).
MB_DB_PASS=change-me

# Key used to encrypt saved data-source credentials at rest. Generate a random
# 32+ byte value, e.g.: openssl rand -base64 32   (do NOT change once set, or saved
# connection secrets become unreadable).
MB_ENCRYPTION_SECRET_KEY=change-me

# LDAP/AD bind account (mirrors vpn-ldap/ldap.env — Metabase uses its own var names).
LDAP_APP_DN=CN=React_LDAP_User,CN=Users,DC=ckk-tools,DC=loc
LDAP_APP_PASSWORD=your_ldap_bind_password
