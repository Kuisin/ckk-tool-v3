{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "GPU Utilization",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        { "expr": "amdgpu_busy_percent", "legendFormat": "{{card}}", "refId": "A" }
      ]
    },
    {
      "title": "VRAM Used (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "amdgpu_vram_used_bytes / amdgpu_vram_total_bytes * 100", "legendFormat": "{{card}}", "refId": "A" }
      ]
    },
    {
      "title": "GPU Temperature",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "amdgpu_temperature_celsius", "legendFormat": "{{card}}", "refId": "A" }
      ]
    },
    {
      "title": "GPU Power",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "watt" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        { "expr": "amdgpu_power_watts", "legendFormat": "{{card}}", "refId": "A" }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 5,
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "cpu", "refId": "A" }
      ]
    },
    {
      "title": "RAM Usage (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 6,
      "targets": [
        { "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "ram", "refId": "A" }
      ]
    },
    {
      "title": "Container Memory (top)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 7,
      "targets": [
        { "expr": "topk(8, container_memory_working_set_bytes{name!=\"\"})", "legendFormat": "{{name}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["hardware", "amd-gpu"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "AMD GPU & System",
  "uid": "amd-gpu-system",
  "version": 1
}
