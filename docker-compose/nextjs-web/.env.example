# Build-time app version shown in the footer.
NEXT_PUBLIC_APP_VERSION=0.1.0

# Cloudflare Tunnel token (remotely-managed tunnel). Get it from the Cloudflare
# Zero Trust dashboard: Networks > Tunnels > (create/select) > install connector,
# copy the token from the `cloudflared ... run <TOKEN>` command. Required only
# when starting the `cloudflare` profile.
CLOUDFLARE_TUNNEL_TOKEN=
