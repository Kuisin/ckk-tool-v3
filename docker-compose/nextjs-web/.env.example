# Build-time app version shown in the footer.
NEXT_PUBLIC_APP_VERSION=0.1.0

# Public access (Cloudflare Tunnel) now lives in the separate `cloudflared` stack.

# ─── Auth.js v5 (認証) ───────────────────────────────────────────────────────
# 本番/dev の値は Coolify の環境変数で管理する（このファイルはコミット用の雛形で、
# 実際の秘密値は入れない）。ローカル検証時のみ .env に実値を置く。

# セッション JWT の署名鍵（必須）。`openssl rand -base64 32` などで生成し、
# 再起動をまたいで固定する（変わると全セッションが無効化）。
AUTH_SECRET=

# Authentik SSO（OIDC）。3つが揃うとログイン画面の「SSO でログイン」が有効化される
# （src/auth.ts の authentikEnabled）。未設定ならデモ用 credentials のみ。
# ISSUER は **末尾スラッシュなし**（provider が /.well-known/openid-configuration を付与）:
#   例) http://auth.ckk-tools.loc:9000/application/o/ckk-business-management
# コールバック URL は Authentik 側に /api/auth/callback/authentik を登録する。
# 注意: この issuer は Next.js コンテナ（サーバー側の discovery/token 取得）と
# ユーザーのブラウザ（authorize への上位遷移）の双方から到達可能である必要がある。
AUTH_AUTHENTIK_ISSUER=
AUTH_AUTHENTIK_ID=
AUTH_AUTHENTIK_SECRET=

# プロキシ（cloudflared/socat）越しでも trustHost=true で Host を信頼するため通常は不要。
# 明示したい場合のみ設定する（例: https://ckk-dev.kai-lab.net）。
# AUTH_URL=
