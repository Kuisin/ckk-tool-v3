// 在庫 (_specs/tables.md §4・§5・§7): 製品在庫 / 素材在庫 / 引当予約 / 在庫取引。
//
// 方針:
// - 実在庫は全工程完了時にのみ動く（製造中は予約のみ — §7）。
// - product_inventory はロット（=指示書番号）単位。半製品は is_semi_finished
//   フラグ + source_step_id（発生工程のトレーサビリティ）で同一台帳に持つ。
// - inventory_transactions が唯一の増減記録（applyTransaction 経由でのみ
//   キャッシュ数量を更新する — lib/inventory.ts）。

enum InventoryType {
  PRODUCT
  MATERIAL

  @@map("INVENTORY_TYPE")
  @@schema("app")
}

enum ReservationStatus {
  RESERVED // 予約中（製造中）
  CONFIRMED // 確定（全工程完了時）
  RELEASED // 解除（出荷・キャンセル）

  @@map("RESERVATION_STATUS")
  @@schema("app")
}

enum TransactionType {
  IN // 入庫
  OUT // 出庫
  RESERVE // 予約
  RELEASE // 予約解除
  ADJUST // 棚卸調整

  @@map("TRANSACTION_TYPE")
  @@schema("app")
}

model ProductInventory {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId      Int     @map("product_id")
  factoryId      Int?    @map("factory_id")
  lotNumber      Int?    @map("lot_number") // ロット = 指示書番号
  quantity       Int     @default(0)
  reservedQuantity Int   @default(0) @map("reserved_quantity")
  isSemiFinished Boolean @default(false) @map("is_semi_finished") // 半製品
  sourceStepId   String? @map("source_step_id") @db.Uuid // 半製品の発生工程
  location       String?
  notes          String?
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product  @relation(fields: [productId], references: [id])
  factory Factory? @relation(fields: [factoryId], references: [id])

  @@unique([productId, factoryId, lotNumber, isSemiFinished])
  @@index([productId])
  @@map("product_inventory")
  @@schema("app")
}

model MaterialInventory {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  materialId       Int     @map("material_id")
  factoryId        Int?    @map("factory_id")
  quantity         Decimal @default(0) @db.Decimal(12, 3)
  reservedQuantity Decimal @default(0) @map("reserved_quantity") @db.Decimal(12, 3)
  unit             String
  location         String?
  notes            String?
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  material Material @relation(fields: [materialId], references: [id])
  factory  Factory? @relation(fields: [factoryId], references: [id])

  @@unique([materialId, factoryId])
  @@index([materialId])
  @@map("material_inventory")
  @@schema("app")
}

// 在庫引当・予約（全工程完了まで予約状態を維持 — §4/§7）
model InventoryReservation {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inventoryType InventoryType     @map("inventory_type")
  inventoryId   String            @map("inventory_id") @db.Uuid
  salesOrderId  String?           @map("sales_order_id") @db.Uuid
  workOrderId   String?           @map("work_order_id") @db.Uuid
  quantity      Decimal           @db.Decimal(12, 3)
  status        ReservationStatus @default(RESERVED)
  reservedAt    DateTime?         @map("reserved_at") @db.Timestamptz(6)
  confirmedAt   DateTime?         @map("confirmed_at") @db.Timestamptz(6)
  releasedAt    DateTime?         @map("released_at") @db.Timestamptz(6)

  salesOrder SalesOrder? @relation(fields: [salesOrderId], references: [id])
  workOrder  WorkOrder?  @relation(fields: [workOrderId], references: [id])

  @@index([inventoryType, inventoryId, status])
  @@index([salesOrderId])
  @@map("inventory_reservations")
  @@schema("app")
}

// 在庫取引（増減の唯一の記録。lib/inventory.ts applyTransaction 経由）
model InventoryTransaction {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inventoryType   InventoryType   @map("inventory_type")
  inventoryId     String          @map("inventory_id") @db.Uuid
  transactionType TransactionType @map("transaction_type")
  quantity        Decimal         @db.Decimal(12, 3)
  referenceType   String?         @map("reference_type") // work_order / shipping_order / material_receipt …
  referenceId     String?         @map("reference_id")
  notes           String?
  createdBy       String?         @map("created_by") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([inventoryType, inventoryId, createdAt])
  @@map("inventory_transactions")
  @@schema("app")
}
