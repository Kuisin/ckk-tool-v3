// 素材・製品マスタ (_specs/tables.md §Master Data).

enum MaterialForm {
  POLISHED
  STANDARD_LENGTH
  SEMI_FINISHED
  OTHER

  @@map("MATERIAL_FORM")
  @@schema("master")
}

// 材種: [A-Z][0-9]{2}[A-Z][0-9]{4} 例: A01A0001
model MaterialType {
  id          String   @id
  name        Json
  description Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  materials Material[]

  @@map("material_types")
  @@schema("master")
}

// 素材: [材種コード]-[A-C][0-9]{3}-[0-9]{3} 例: A01A0001-A001-001
model Material {
  id             String       @id
  materialTypeId String       @map("material_type_id")
  name           Json
  unit           String
  materialForm   MaterialForm @map("material_form")
  isActive       Boolean      @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  materialType MaterialType @relation(fields: [materialTypeId], references: [id])
  products     Product[]
  estimates    Estimate[]

  @@map("materials")
  @@schema("master")
}

// 製品コード: PRD-YYYYMM-NNNN
model Product {
  id         String   @id
  name       Json
  materialId String?  @map("material_id")
  unit       String   @default("本")
  spec       Json?
  isActive   Boolean  @default(true) @map("is_active")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  material         Material?        @relation(fields: [materialId], references: [id])
  priceListEntries PriceListEntry[]
  quoteItems       QuoteItem[]

  @@map("products")
  @@schema("master")
}
