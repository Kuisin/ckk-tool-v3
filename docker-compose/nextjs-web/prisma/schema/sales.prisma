// 販売 — 試算・価格表・見積書 (_specs/tables.md §1 + SA05, UI model準拠).
//
// フロー: 試算 (SA05 見積試算, EST-) → 確定後に価格表登録（試算の見積単価が
// 基準単価）→ 見積書 (QOT-) は価格表 (倍率 tiers + 値引きルール) からのみ
// 価格を解決する。
//
// キー方針: 文書テーブルは複合キー (year_month + seq) — 文書番号
// EST-YYYYMM-NNNNN / QOT-YYYYMM-NNNNN はキーから導出し、単一カラムには
// 保存しない。価格表エントリは自然複合キー (顧客, 製品, 注文種別)。

enum OrderType {
  PRODUCTION
  TEST
  SAMPLE
  OTHER

  @@map("ORDER_TYPE")
  @@schema("sales")
}

enum TrialToolType {
  ROUND_BAR
  CYLINDER
  OH

  @@map("TRIAL_TOOL_TYPE")
  @@schema("sales")
}

enum EstimateStatus {
  DRAFT
  CONFIRMED
  REGISTERED

  @@map("ESTIMATE_STATUS")
  @@schema("sales")
}

enum QuoteStatus {
  DRAFT
  ISSUED
  ACCEPTED
  REJECTED
  EXPIRED

  @@map("QUOTE_STATUS")
  @@schema("sales")
}

enum PriceDiscountType {
  RATE
  AMOUNT

  @@map("PRICE_DISCOUNT_TYPE")
  @@schema("sales")
}

// 試算 (SA05 見積試算) — 計算入力のスナップショット + 参照価格。
// 文書番号 EST-{year_month}-{seq:5桁} はキーから導出。
model Estimate {
  yearMonth String @map("year_month") @db.Char(6)
  seq       Int

  name                String
  toolType            TrialToolType  @map("tool_type")
  status              EstimateStatus @default(DRAFT)
  customerBpId        String?        @map("customer_bp_id") @db.Uuid
  materialId          String?        @map("material_id")
  // 参照価格（仕入実績由来）。reference_overridden = 手動上書き。
  referenceUnitPrice  Decimal?       @map("reference_unit_price") @db.Decimal(12, 2)
  referenceDate       DateTime?      @map("reference_date") @db.Date
  referenceOverridden Boolean        @default(false) @map("reference_overridden")
  // 入力スナップショット（lib/trial-pricing TrialInput）
  input               Json
  // 算出結果スナップショット（任意 — 表示は input から再計算）
  result              Json?
  registeredAt        DateTime?      @map("registered_at") @db.Timestamptz(6)
  notes               String?
  createdBy           String?        @map("created_by") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp    BusinessPartner? @relation("EstimateCustomer", fields: [customerBpId], references: [id])
  material      Material?        @relation(fields: [materialId], references: [id])
  createdByUser User?            @relation("EstimateCreatedBy", fields: [createdBy], references: [id])

  priceListEntries PriceListEntry[]

  @@id([yearMonth, seq])
  @@map("estimates")
  @@schema("sales")
}

// 価格表エントリ — 自然複合キー (顧客, 製品, 注文種別)。作成後不変。
// 基準単価 = 試算の見積単価（手動上書き可）。tier 単価は基準単価×倍率。
model PriceListEntry {
  customerBpId String    @map("customer_bp_id") @db.Uuid
  productId    String    @map("product_id")
  orderType    OrderType @map("order_type")

  currency          String    @default("JPY")
  baseUnitPrice     Decimal   @default(0) @map("base_unit_price") @db.Decimal(12, 2)
  validFrom         DateTime  @map("valid_from") @db.Date
  validUntil        DateTime? @map("valid_until") @db.Date
  estimateYearMonth String?   @map("estimate_year_month") @db.Char(6)
  estimateSeq       Int?      @map("estimate_seq")
  isActive          Boolean   @default(true) @map("is_active")
  createdBy         String?   @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp    BusinessPartner @relation("PriceListEntryCustomer", fields: [customerBpId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  estimate      Estimate?       @relation(fields: [estimateYearMonth, estimateSeq], references: [yearMonth, seq])
  createdByUser User?           @relation("PriceListEntryCreatedBy", fields: [createdBy], references: [id])
  tiers         PriceListTier[]
  discounts     PriceListDiscount[]

  @@id([customerBpId, productId, orderType])
  @@map("price_list_entries")
  @@schema("sales")
}

// 数量段階: 数量範囲 → 倍率。単価 = round(基準単価 × 倍率)、
// price_override で行ごとに手動上書き可（null = 自動計算）。
model PriceListTier {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerBpId  String    @map("customer_bp_id") @db.Uuid
  productId     String    @map("product_id")
  orderType     OrderType @map("order_type")
  minQuantity   Int       @default(1) @map("min_quantity")
  maxQuantity   Int?      @map("max_quantity")
  multiplier    Decimal   @default(1) @db.Decimal(8, 3)
  priceOverride Decimal?  @map("price_override") @db.Decimal(12, 2)
  sortOrder     Int       @default(0) @map("sort_order")

  entry PriceListEntry @relation(fields: [customerBpId, productId, orderType], references: [customerBpId, productId, orderType])

  quoteItems QuoteItem[]

  @@index([customerBpId, productId, orderType, minQuantity])
  @@map("price_list_tiers")
  @@schema("sales")
}

// 値引きルール — 期間 × 数量条件 → 値引き（entry ごとの専用リスト）。
// RATE = 単価に対する率(%) / AMOUNT = 1本あたりの値引き額(¥)。
// 条件を満たすルールのうち 1本あたり値引きが最大のものを適用する。
model PriceListDiscount {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerBpId String            @map("customer_bp_id") @db.Uuid
  productId    String            @map("product_id")
  orderType    OrderType         @map("order_type")
  label        String
  discountType PriceDiscountType @map("discount_type")
  value        Decimal           @db.Decimal(12, 2)
  minQuantity  Int               @default(1) @map("min_quantity")
  maxQuantity  Int?              @map("max_quantity")
  validFrom    DateTime          @map("valid_from") @db.Date
  validUntil   DateTime?         @map("valid_until") @db.Date
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  entry PriceListEntry @relation(fields: [customerBpId, productId, orderType], references: [customerBpId, productId, orderType])

  @@index([customerBpId, productId, orderType])
  @@map("price_list_discounts")
  @@schema("sales")
}

// 見積書 — 文書番号 QOT-{year_month}-{seq:5桁} はキーから導出。
// 価格は価格表からのみ解決（手入力なし・印刷用文書）。
model Quote {
  yearMonth String @map("year_month") @db.Char(6)
  seq       Int

  customerBpId       String      @map("customer_bp_id") @db.Uuid
  customerBranchBpId String?     @map("customer_branch_bp_id") @db.Uuid
  status             QuoteStatus @default(DRAFT)
  validUntil         DateTime?   @map("valid_until") @db.Date
  notes              String?
  pdfFileId          String?     @map("pdf_file_id") @db.Uuid
  createdBy          String?     @map("created_by") @db.Uuid
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp       BusinessPartner  @relation("QuoteCustomer", fields: [customerBpId], references: [id])
  customerBranchBp BusinessPartner? @relation("QuoteCustomerBranch", fields: [customerBranchBpId], references: [id])
  pdfFile          File?            @relation("QuotePdf", fields: [pdfFileId], references: [id])
  createdByUser    User?            @relation("QuoteCreatedBy", fields: [createdBy], references: [id])
  items            QuoteItem[]

  @@id([yearMonth, seq])
  @@map("quotes")
  @@schema("sales")
}

model QuoteItem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteYearMonth String    @map("quote_year_month") @db.Char(6)
  quoteSeq       Int       @map("quote_seq")
  productId      String    @map("product_id")
  orderType      OrderType @map("order_type")
  quantity       Int
  unitPrice      Decimal   @map("unit_price") @db.Decimal(12, 2)
  // 自動解決元の価格表 tier（価格表なしの旧データのみ null）
  priceListTierId String?  @map("price_list_tier_id") @db.Uuid
  // 値引きルールから自動計算された明細値引き（スナップショット）
  discountAmount Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountLabel  String?   @map("discount_label")
  amount         Decimal   @db.Decimal(12, 2)
  deliveryDate   DateTime? @map("delivery_date") @db.Date
  notes          String?
  sortOrder      Int       @default(0) @map("sort_order")

  quote         Quote          @relation(fields: [quoteYearMonth, quoteSeq], references: [yearMonth, seq])
  product       Product        @relation(fields: [productId], references: [id])
  priceListTier PriceListTier? @relation(fields: [priceListTierId], references: [id])

  @@map("quote_items")
  @@schema("sales")
}
