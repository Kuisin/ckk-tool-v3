// 出荷・納品 (_specs/tables.md §8).

enum ShippingType {
  STOCK_STORAGE
  DISPATCH

  @@map("SHIPPING_TYPE")
  @@schema("shipping")
}

enum ShippingStatus {
  DRAFT
  CONFIRMED
  SHIPPED

  @@map("SHIPPING_STATUS")
  @@schema("shipping")
}

enum DeliveryMethod {
  DIRECT_TO_USER
  NORMAL

  @@map("DELIVERY_METHOD")
  @@schema("shipping")
}

enum DeliveryStatus {
  DRAFT
  ISSUED
  DELIVERED

  @@map("DELIVERY_STATUS")
  @@schema("shipping")
}

model ShippingOrder {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salesOrderId String         @map("sales_order_id") @db.Uuid
  workOrderId  String?        @map("work_order_id") @db.Uuid
  type         ShippingType
  status       ShippingStatus @default(DRAFT)
  shippedAt    DateTime?      @map("shipped_at") @db.Timestamptz(6)
  notes        String?
  createdBy    String?        @map("created_by") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id])
  createdByUser User?      @relation("ShippingOrderCreatedBy", fields: [createdBy], references: [id])

  items         ShippingOrderItem[]
  deliveryNotes DeliveryNote[]
  invoiceItems  InvoiceItem[]

  @@map("shipping_orders")
  @@schema("shipping")
}

model ShippingOrderItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shippingOrderId String  @map("shipping_order_id") @db.Uuid
  productId       String  @map("product_id")
  lotNumber       Int?    @map("lot_number")
  quantity        Int
  notes           String?
  sortOrder       Int     @default(0) @map("sort_order")

  shippingOrder ShippingOrder @relation(fields: [shippingOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@map("shipping_order_items")
  @@schema("shipping")
}

// 納品書 DRN-YYYYMM-NNNNN
model DeliveryNote {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryNumber      String         @unique @map("delivery_number")
  shippingOrderId     String         @map("shipping_order_id") @db.Uuid
  deliveryMethod      DeliveryMethod @map("delivery_method")
  recipientBpId       String         @map("recipient_bp_id") @db.Uuid
  recipientBranchBpId String?        @map("recipient_branch_bp_id") @db.Uuid
  endUserBpId         String?        @map("end_user_bp_id") @db.Uuid
  includePrice        Boolean        @default(true) @map("include_price")
  pdfFileId           String?        @map("pdf_file_id") @db.Uuid
  status              DeliveryStatus @default(DRAFT)
  deliveredAt         DateTime?      @map("delivered_at") @db.Timestamptz(6)
  notes               String?
  createdBy           String?        @map("created_by") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  shippingOrder     ShippingOrder    @relation(fields: [shippingOrderId], references: [id])
  recipientBp       BusinessPartner  @relation("DeliveryNoteRecipient", fields: [recipientBpId], references: [id])
  recipientBranchBp BusinessPartner? @relation("DeliveryNoteRecipientBranch", fields: [recipientBranchBpId], references: [id])
  endUserBp         BusinessPartner? @relation("DeliveryNoteEndUser", fields: [endUserBpId], references: [id])
  pdfFile           File?            @relation("DeliveryNotePdf", fields: [pdfFileId], references: [id])
  createdByUser     User?            @relation("DeliveryNoteCreatedBy", fields: [createdBy], references: [id])

  items        DeliveryNoteItem[]
  invoiceItems InvoiceItem[]

  @@map("delivery_notes")
  @@schema("shipping")
}

model DeliveryNoteItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryNoteId String   @map("delivery_note_id") @db.Uuid
  productId      String   @map("product_id")
  quantity       Int
  unitPrice      Decimal? @map("unit_price") @db.Decimal(12, 2)
  amount         Decimal? @db.Decimal(12, 2)
  notes          String?
  sortOrder      Int      @default(0) @map("sort_order")

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@map("delivery_note_items")
  @@schema("shipping")
}
