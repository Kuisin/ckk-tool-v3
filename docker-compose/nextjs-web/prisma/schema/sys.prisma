// ファイル・採番 (_specs/tables.md §Other).

// SeaweedFS オブジェクト
model File {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storageKey String   @map("storage_key")
  filename   String
  mimeType   String   @map("mime_type")
  sizeBytes  BigInt?  @map("size_bytes")
  uploadedBy String?  @map("uploaded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  uploadedByUser User? @relation("FileUploadedBy", fields: [uploadedBy], references: [id])

  quotesPdf        Quote[]        @relation("QuotePdf")
  deliveryNotesPdf DeliveryNote[] @relation("DeliveryNotePdf")
  invoicesPdf      Invoice[]      @relation("InvoicePdf")

  @@map("files")
  @@schema("app")
}

// システム設定（試算の価格ポリシーなど。feature_flags 同様の単純 KV）
// キー例: trial_pricing.material_price_basis / trial_pricing.lookback_months
model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  updatedByUser User? @relation("SystemSettingUpdatedBy", fields: [updatedBy], references: [id])

  @@map("system_settings")
  @@schema("app")
}

// 採番管理（EST/QOT — 月次リセット）
model NumberingSequence {
  key           String   @id
  prefix        String
  lastYearMonth String?  @map("last_year_month")
  lastSequence  Int      @default(0) @map("last_sequence")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("numbering_sequences")
  @@schema("app")
}

// フィーチャーフラグ（_specs/tables.md §Other）。アプリの環境別 ON/OFF に使用:
// key = `app:<appKey>:<env>`（env = dev | main）。行が無ければ有効（デフォルト
// ON — 既存挙動を変えない）。dev/main は同一 DB を共有するため env をキーに含める。
model FeatureFlag {
  key         String   @id
  isEnabled   Boolean  @default(false) @map("is_enabled")
  description String?
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  updatedByUser User? @relation("FeatureFlagUpdatedBy", fields: [updatedBy], references: [id])

  @@map("feature_flags")
  @@schema("app")
}

// 監査ログ（業務操作履歴）。各レコードの CREATE/UPDATE/DELETE を before/after
// JSON 付きで記録し、詳細画面の「履歴」タブと管理者向け操作履歴一覧で表示する。
// record_id は業務識別子（文書番号 QOT-… / EST-…、価格表エントリキー、
// マスタの文字列 id）を格納する TEXT — 文書テーブルが複合キーのため uuid ではない。
// user_id は認証実装後に実ユーザーへ解決する弱参照（現状は null 可）。
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  action     String // CREATE / UPDATE / DELETE
  tableName  String   @map("table_name") // quotes / estimates / price_list_entries / products …
  recordId   String?  @map("record_id") // 業務識別子（文書番号・エントリキー・id）
  beforeData Json?    @map("before_data")
  afterData  Json?    @map("after_data")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation("AuditLogUser", fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("app")
}
