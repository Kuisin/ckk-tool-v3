// 請求 (_specs/tables.md §9).

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID

  @@map("INVOICE_STATUS")
  @@schema("billing")
}

enum ClosingStatus {
  PENDING
  PROCESSED
  EXPORTED

  @@map("CLOSING_STATUS")
  @@schema("billing")
}

// 請求書 INV-YYYYMM-NNNNN
model Invoice {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber      String        @unique @map("invoice_number")
  customerBpId       String        @map("customer_bp_id") @db.Uuid
  customerBranchBpId String?       @map("customer_branch_bp_id") @db.Uuid
  billingPeriodFrom  DateTime      @map("billing_period_from") @db.Date
  billingPeriodTo    DateTime      @map("billing_period_to") @db.Date
  subtotal           Decimal       @db.Decimal(12, 2)
  taxAmount          Decimal       @map("tax_amount") @db.Decimal(12, 2)
  totalAmount        Decimal       @map("total_amount") @db.Decimal(12, 2)
  status             InvoiceStatus @default(DRAFT)
  issuedAt           DateTime?     @map("issued_at") @db.Timestamptz(6)
  dueDate            DateTime?     @map("due_date") @db.Date
  sentAt             DateTime?     @map("sent_at") @db.Timestamptz(6)
  pdfFileId          String?       @map("pdf_file_id") @db.Uuid
  yayoiExportedAt    DateTime?     @map("yayoi_exported_at") @db.Timestamptz(6)
  notes              String?
  createdBy          String?       @map("created_by") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp       BusinessPartner  @relation("InvoiceCustomer", fields: [customerBpId], references: [id])
  customerBranchBp BusinessPartner? @relation("InvoiceCustomerBranch", fields: [customerBranchBpId], references: [id])
  pdfFile          File?            @relation("InvoicePdf", fields: [pdfFileId], references: [id])
  createdByUser    User?            @relation("InvoiceCreatedBy", fields: [createdBy], references: [id])
  items            InvoiceItem[]

  @@map("invoices")
  @@schema("billing")
}

model InvoiceItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId       String  @map("invoice_id") @db.Uuid
  shippingOrderId String? @map("shipping_order_id") @db.Uuid
  deliveryNoteId  String? @map("delivery_note_id") @db.Uuid
  description     Json
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(12, 2)
  amount          Decimal @db.Decimal(12, 2)
  sortOrder       Int     @default(0) @map("sort_order")

  invoice       Invoice        @relation(fields: [invoiceId], references: [id])
  shippingOrder ShippingOrder? @relation(fields: [shippingOrderId], references: [id])
  deliveryNote  DeliveryNote?  @relation(fields: [deliveryNoteId], references: [id])

  @@map("invoice_items")
  @@schema("billing")
}

model BillingClosing {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerBpId String        @map("customer_bp_id") @db.Uuid
  closingDate  DateTime      @map("closing_date") @db.Date
  status       ClosingStatus @default(PENDING)
  totalAmount  Decimal?      @map("total_amount") @db.Decimal(12, 2)
  processedAt  DateTime?     @map("processed_at") @db.Timestamptz(6)
  processedBy  String?       @map("processed_by") @db.Uuid
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  customerBp      BusinessPartner @relation("ClosingCustomer", fields: [customerBpId], references: [id])
  processedByUser User?           @relation("ClosingProcessedBy", fields: [processedBy], references: [id])

  @@map("billing_closings")
  @@schema("billing")
}
