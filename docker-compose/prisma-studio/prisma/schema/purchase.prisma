// 素材発注・入荷 (_specs/tables.md §素材発注). 購買は素材 (materials) 単位で管理する。
// PU01/PU03 の画面は後続タスク — 本ファイルはテーブル + 試算参照価格の
// データ源（仕入実績 = material_purchase_order_items）として先行導入。
// factory_id (入荷先工場) は inventory 導入時に追加済み（ATP の工場別集計に使用）。
// material_purchase_approvers は承認フロー導入時に追加する。 // TODO

enum PurchaseStatus {
  DRAFT
  REQUESTED
  APPROVED
  ORDERED
  COMPLETED
  CANCELLED

  @@map("PURCHASE_STATUS")
  @@schema("app")
}

// 素材発注書: PO-YYYYMM-NNNNN（承認フロー: 依頼→承認→発注→入荷）
model MaterialPurchaseOrder {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poNumber     String         @unique @map("po_number")
  supplierBpId String         @map("supplier_bp_id") @db.Uuid
  status       PurchaseStatus @default(DRAFT)
  totalAmount  Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency     String         @default("JPY")
  purchaseDate DateTime?      @map("purchase_date") @db.Date
  requestedAt  DateTime?      @map("requested_at") @db.Timestamptz(6)
  requestedBy  String?        @map("requested_by") @db.Uuid
  approvedAt   DateTime?      @map("approved_at") @db.Timestamptz(6)
  approvedBy   String?        @map("approved_by") @db.Uuid
  orderedAt    DateTime?      @map("ordered_at") @db.Timestamptz(6)
  orderedBy    String?        @map("ordered_by") @db.Uuid
  completedAt  DateTime?      @map("completed_at") @db.Timestamptz(6)
  completedBy  String?        @map("completed_by") @db.Uuid
  cancelledAt  DateTime?      @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy  String?        @map("cancelled_by") @db.Uuid
  cancelReason String?        @map("cancel_reason")
  // 状態遷移履歴 [{ action, user, at, notes }]
  history      Json?
  notes        String?
  createdBy    String?        @map("created_by") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  supplierBp      BusinessPartner @relation("PoSupplier", fields: [supplierBpId], references: [id])
  requestedByUser User?           @relation("PoRequestedBy", fields: [requestedBy], references: [id])
  approvedByUser  User?           @relation("PoApprovedBy", fields: [approvedBy], references: [id])
  orderedByUser   User?           @relation("PoOrderedBy", fields: [orderedBy], references: [id])
  completedByUser User?           @relation("PoCompletedBy", fields: [completedBy], references: [id])
  cancelledByUser User?           @relation("PoCancelledBy", fields: [cancelledBy], references: [id])
  createdByUser   User?           @relation("PoCreatedBy", fields: [createdBy], references: [id])

  items MaterialPurchaseOrderItem[]

  @@index([status])
  @@index([supplierBpId])
  @@map("material_purchase_orders")
  @@schema("app")
}

model MaterialPurchaseOrderItem {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String    @map("purchase_order_id") @db.Uuid
  materialId        Int       @map("material_id")
  quantity        Decimal   @db.Decimal(12, 3)
  unit            String
  unitPrice       Decimal   @map("unit_price") @db.Decimal(12, 2)
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("JPY")
  expectedAt      DateTime? @map("expected_at") @db.Date
  factoryId       Int?      @map("factory_id") // 入荷先工場
  notes           String?
  sortOrder       Int       @default(0) @map("sort_order")

  purchaseOrder MaterialPurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  material      Material              @relation(fields: [materialId], references: [id])
  factory       Factory?              @relation("PoItemFactory", fields: [factoryId], references: [id])
  receipts      MaterialReceipt[]

  @@index([purchaseOrderId])
  @@index([materialId])
  @@map("material_purchase_order_items")
  @@schema("app")
}

// 素材入荷（発注の入荷 or 外部調達の直接入荷）
model MaterialReceipt {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  materialId        Int       @map("material_id")
  supplierBpId        String?  @map("supplier_bp_id") @db.Uuid
  purchaseOrderItemId String?  @map("purchase_order_item_id") @db.Uuid
  quantity            Decimal  @db.Decimal(12, 3)
  unit                String
  receivedAt          DateTime @map("received_at") @db.Date
  factoryId           Int?     @map("factory_id") // 入荷先工場
  notes               String?
  createdBy           String?  @map("created_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  material          Material                   @relation(fields: [materialId], references: [id])
  factory           Factory?                   @relation("ReceiptFactory", fields: [factoryId], references: [id])
  supplierBp        BusinessPartner?           @relation("ReceiptSupplier", fields: [supplierBpId], references: [id])
  purchaseOrderItem MaterialPurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  createdByUser     User?                      @relation("ReceiptCreatedBy", fields: [createdBy], references: [id])

  @@index([materialId, receivedAt])
  @@map("material_receipts")
  @@schema("app")
}
