// 販売 — 価格表・見積書・注文受諾書 (_specs/tables.md §1・§2).

enum OrderType {
  PRODUCTION
  TEST
  SAMPLE
  OTHER

  @@map("ORDER_TYPE")
  @@schema("sales")
}

enum QuoteStatus {
  DRAFT
  ISSUED
  ACCEPTED
  REJECTED
  EXPIRED

  @@map("QUOTE_STATUS")
  @@schema("sales")
}

enum OrderAcceptanceStatus {
  PENDING
  PRICE_DIFF
  CONFIRMED

  @@map("ORDER_ACCEPTANCE_STATUS")
  @@schema("sales")
}

// 顧客 + 製品 + 注文種別 + 本数 → 単価。有効日で管理。
model PriceList {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerBpId String    @map("customer_bp_id") @db.Uuid
  productId    String    @map("product_id")
  orderType    OrderType @map("order_type")
  minQuantity  Int       @default(1) @map("min_quantity")
  maxQuantity  Int?      @map("max_quantity")
  unitPrice    Decimal   @map("unit_price") @db.Decimal(12, 2)
  currency     String    @default("JPY")
  validFrom    DateTime  @map("valid_from") @db.Date
  validUntil   DateTime? @map("valid_until") @db.Date
  isActive     Boolean   @default(true) @map("is_active")
  createdBy    String?   @map("created_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp    BusinessPartner @relation("PriceListCustomer", fields: [customerBpId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  createdByUser User?           @relation("PriceListCreatedBy", fields: [createdBy], references: [id])
  quoteItems    QuoteItem[]

  @@map("price_lists")
  @@schema("sales")
}

// 見積書 QOT-YYYYMM-NNNNN
model Quote {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteNumber        String      @unique @map("quote_number")
  customerBpId       String      @map("customer_bp_id") @db.Uuid
  customerBranchBpId String?     @map("customer_branch_bp_id") @db.Uuid
  status             QuoteStatus @default(DRAFT)
  validUntil         DateTime?   @map("valid_until") @db.Date
  notes              String?
  pdfFileId          String?     @map("pdf_file_id") @db.Uuid
  createdBy          String?     @map("created_by") @db.Uuid
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp       BusinessPartner  @relation("QuoteCustomer", fields: [customerBpId], references: [id])
  customerBranchBp BusinessPartner? @relation("QuoteCustomerBranch", fields: [customerBranchBpId], references: [id])
  pdfFile          File?            @relation("QuotePdf", fields: [pdfFileId], references: [id])
  createdByUser    User?            @relation("QuoteCreatedBy", fields: [createdBy], references: [id])
  items            QuoteItem[]
  orderAcceptances OrderAcceptance[]
  designRequests   DesignRequest[]

  @@map("quotes")
  @@schema("sales")
}

model QuoteItem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId        String    @map("quote_id") @db.Uuid
  productId      String    @map("product_id")
  orderType      OrderType @map("order_type")
  quantity       Int
  unitPrice      Decimal   @map("unit_price") @db.Decimal(12, 2)
  priceListId    String?   @map("price_list_id") @db.Uuid
  discountAmount Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  amount         Decimal   @db.Decimal(12, 2)
  deliveryDate   DateTime? @map("delivery_date") @db.Date
  notes          String?
  sortOrder      Int       @default(0) @map("sort_order")

  quote     Quote      @relation(fields: [quoteId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])
  priceList PriceList? @relation(fields: [priceListId], references: [id])

  @@map("quote_items")
  @@schema("sales")
}

// 注文受諾書 ORD-YYYYMM-NNNNN
model OrderAcceptance {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber        String                @unique @map("order_number")
  quoteId            String?               @map("quote_id") @db.Uuid
  customerBpId       String                @map("customer_bp_id") @db.Uuid
  customerBranchBpId String?               @map("customer_branch_bp_id") @db.Uuid
  customerOrderRef   String?               @map("customer_order_ref")
  status             OrderAcceptanceStatus @default(PENDING)
  totalAmount        Decimal?              @map("total_amount") @db.Decimal(12, 2)
  orderDocFileId     String?               @map("order_doc_file_id") @db.Uuid
  notes              String?
  createdBy          String?               @map("created_by") @db.Uuid
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  quote            Quote?           @relation(fields: [quoteId], references: [id])
  customerBp       BusinessPartner  @relation("OrderAcceptanceCustomer", fields: [customerBpId], references: [id])
  customerBranchBp BusinessPartner? @relation("OrderAcceptanceCustomerBranch", fields: [customerBranchBpId], references: [id])
  orderDocFile     File?            @relation("OrderAcceptanceDoc", fields: [orderDocFileId], references: [id])
  createdByUser    User?            @relation("OrderAcceptanceCreatedBy", fields: [createdBy], references: [id])
  salesOrders      SalesOrder[]

  @@map("order_acceptances")
  @@schema("sales")
}
