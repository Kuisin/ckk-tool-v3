// 出荷・納品 (_specs/tables.md §8): 出荷書 / 納品書。
//
// 番号付き印刷文書 = Quote と同じ (year_month, seq) 複合キー。表示番号
// SHP-YYYYMM-NNNNN / DRN-YYYYMM-NNNNN は導出（URL id にも使用）。
// 出荷書はヘッダで受注書（+任意で指示書）に紐付き、明細は製品×ロット —
// 複数指示書（ロット）の成果を 1 出荷書に束ねられる。納品書は出荷書 1:1。

enum ShippingType {
  STOCK_STORAGE // 在庫保管（予備製作分・請求フロー外）
  DISPATCH // 発送（§9 会計トリガ）

  @@map("SHIPPING_TYPE")
  @@schema("app")
}

enum ShippingStatus {
  DRAFT
  CONFIRMED
  SHIPPED

  @@map("SHIPPING_STATUS")
  @@schema("app")
}

enum DeliveryMethod {
  DIRECT_TO_USER // ユーザー直送（完了書に価格なし、納品書別送）
  NORMAL // 通常納品（受注先へ納品書同梱）

  @@map("DELIVERY_METHOD")
  @@schema("app")
}

enum DeliveryStatus {
  DRAFT
  ISSUED
  DELIVERED

  @@map("DELIVERY_STATUS")
  @@schema("app")
}

model ShippingOrder {
  yearMonth String @map("year_month") @db.Char(6)
  seq       Int

  salesOrderId  String  @map("sales_order_id") @db.Uuid
  workOrderId   String? @map("work_order_id") @db.Uuid
  fromFactoryId Int?    @map("from_factory_id")

  type      ShippingType
  status    ShippingStatus @default(DRAFT)
  shippedAt DateTime?      @map("shipped_at") @db.Timestamptz(6)
  notes     String?
  createdBy String?        @map("created_by") @db.Uuid
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id])
  fromFactory   Factory?   @relation(fields: [fromFactoryId], references: [id])
  createdByUser User?      @relation("ShippingOrderCreatedBy", fields: [createdBy], references: [id])

  items         ShippingOrderItem[]
  deliveryNotes DeliveryNote[]

  @@id([yearMonth, seq])
  @@index([salesOrderId])
  @@index([status])
  @@map("shipping_orders")
  @@schema("app")
}

model ShippingOrderItem {
  id                     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shippingOrderYearMonth String @map("shipping_order_year_month") @db.Char(6)
  shippingOrderSeq       Int    @map("shipping_order_seq")

  productId Int     @map("product_id")
  lotNumber Int?    @map("lot_number") // ロット = 指示書番号（複数 WO を束ねる単位）
  quantity  Int
  notes     String?
  sortOrder Int     @default(0) @map("sort_order")

  shippingOrder ShippingOrder @relation(fields: [shippingOrderYearMonth, shippingOrderSeq], references: [yearMonth, seq], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([shippingOrderYearMonth, shippingOrderSeq])
  @@map("shipping_order_items")
  @@schema("app")
}

// 納品書 DRN-YYYYMM-NNNNN
model DeliveryNote {
  yearMonth String @map("year_month") @db.Char(6)
  seq       Int

  shippingOrderYearMonth String @map("shipping_order_year_month") @db.Char(6)
  shippingOrderSeq       Int    @map("shipping_order_seq")

  deliveryMethod       DeliveryMethod @map("delivery_method")
  recipientBpId        String         @map("recipient_bp_id") @db.Uuid
  recipientBranchBpId  String?        @map("recipient_branch_bp_id") @db.Uuid
  endUserBpId          String?        @map("end_user_bp_id") @db.Uuid // ユーザー直送時
  includePrice         Boolean        @default(true) @map("include_price")
  pdfFileId            String?        @map("pdf_file_id") @db.Uuid
  status               DeliveryStatus @default(DRAFT)
  deliveredAt          DateTime?      @map("delivered_at") @db.Timestamptz(6)
  notes                String?
  createdBy            String?        @map("created_by") @db.Uuid
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  shippingOrder     ShippingOrder    @relation(fields: [shippingOrderYearMonth, shippingOrderSeq], references: [yearMonth, seq])
  recipientBp       BusinessPartner  @relation("DeliveryNoteRecipient", fields: [recipientBpId], references: [id])
  recipientBranchBp BusinessPartner? @relation("DeliveryNoteRecipientBranch", fields: [recipientBranchBpId], references: [id])
  endUserBp         BusinessPartner? @relation("DeliveryNoteEndUser", fields: [endUserBpId], references: [id])
  pdfFile           File?            @relation("DeliveryNotePdf", fields: [pdfFileId], references: [id])
  createdByUser     User?            @relation("DeliveryNoteCreatedBy", fields: [createdBy], references: [id])

  items DeliveryNoteItem[]

  @@id([yearMonth, seq])
  @@index([shippingOrderYearMonth, shippingOrderSeq])
  @@map("delivery_notes")
  @@schema("app")
}

model DeliveryNoteItem {
  id                    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryNoteYearMonth String @map("delivery_note_year_month") @db.Char(6)
  deliveryNoteSeq       Int    @map("delivery_note_seq")

  productId Int      @map("product_id")
  quantity  Int
  unitPrice Decimal? @map("unit_price") @db.Decimal(12, 2)
  amount    Decimal? @db.Decimal(12, 2)
  notes     String?
  sortOrder Int      @default(0) @map("sort_order")

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteYearMonth, deliveryNoteSeq], references: [yearMonth, seq], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@index([deliveryNoteYearMonth, deliveryNoteSeq])
  @@map("delivery_note_items")
  @@schema("app")
}
