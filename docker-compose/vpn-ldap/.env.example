# OpenVPN username/password (auth-user-pass). The entrypoint writes the auth file
# from these at runtime, so .env is the single source of truth. Real values live
# only in .env (gitignored) — never commit credentials in this example file.
VPN_USERNAME=your_vpn_user
VPN_PASSWORD=your_vpn_password

# LDAP/AD server address as reachable over the VPN, and its port.
LDAP_HOST=192.168.11.5
LDAP_PORT=389

# ldap-sync service: writes the AD employee directory into PostgreSQL.
# DSN to the shared DB Metabase reads (kot-db). e.g.
#   postgresql://kot:<password>@kot-db:5432/kot
LDAP_SYNC_DB_URL=
# Periodic full-sync interval (seconds; default 6h). A login also triggers a
# (debounced) sync via the bind-aware forwarder.
LDAP_SYNC_INTERVAL_SECONDS=21600
