# Shared LDAP/AD connection + bind credentials — single source of truth, reused by
# any app that authenticates against AD (pulled in via `env_file`). Real values
# live only in ldap.env (gitignored). Variable names match Open WebUI's; apps with
# different names can map these in their own compose.
LDAP_SERVER_LABEL=CKK AD
LDAP_SERVER_HOST=vpn-ldap
LDAP_SERVER_PORT=389
LDAP_APP_DN=CN=React_LDAP_User,CN=Users,DC=ckk-tools,DC=loc
LDAP_APP_PASSWORD=your_ldap_bind_password
LDAP_SEARCH_BASE=DC=ckk-tools,DC=loc
LDAP_ATTRIBUTE_FOR_USERNAME=sAMAccountName
LDAP_ATTRIBUTE_FOR_MAIL=mail
LDAP_USE_TLS=false
