// Admintools (mail account management etc.).
// Writer: admintools app (role admintools, SQLAlchemy).

model MailAccount {
  id            Int      @id @default(autoincrement())
  username      String   @unique(map: "ix_mail_accounts_username") @db.VarChar(64)
  password      String   @db.VarChar(255)
  email         String   @db.VarChar(255)
  quotaGb       Int      @map("quota_gb")
  isActive      Boolean  @map("is_active")
  notes         String
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  kind          String   @default("shared") @db.VarChar(16)
  type          String   @default("other") @db.VarChar(16)
  extraAliases  String   @default("") @map("extra_aliases")
  passwordDirty Boolean  @default(false) @map("password_dirty")

  @@map("mail_accounts")
  @@schema("admintools")
}

model GroupMember {
  id       Int    @id @default(autoincrement())
  groupId  Int    @map("group_id")
  username String @db.VarChar(64)

  @@unique([groupId, username], map: "uq_group_member")
  @@index([groupId], map: "ix_group_members_group_id")
  @@map("group_members")
  @@schema("admintools")
}
