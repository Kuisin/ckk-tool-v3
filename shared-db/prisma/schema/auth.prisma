// Auth / RBAC (_specs/tables.md §Auth).
// The aggregated `user_permissions` view is created in raw SQL inside the
// initial migration — always query the view, not the relation tables.

enum UserGroup {
  SYSTEM
  EMPLOYEE
  GUEST

  @@map("USER_GROUP")
  @@schema("app")
}

enum Action {
  READ
  CREATE
  UPDATE
  DELETE
  EXPORT
  APPROVE
  ADMIN

  @@map("ACTION")
  @@schema("app")
}

enum Scope {
  ALL
  REGION
  COUNTRY
  FACTORY
  DEPARTMENT
  TEAM
  SUB
  OWN

  @@map("SCOPE")
  @@schema("app")
}

model User {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  group       UserGroup
  employeeId  String?   @unique @map("employee_id") @db.Uuid
  username    String    @unique
  displayName String    @map("display_name")
  email       String?
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  roleAssignments         UserRoleRelation[] @relation("UserRoles")
  rolesAssigned           UserRoleRelation[] @relation("UserRolesAssignedBy")
  businessPartnersCreated BusinessPartner[]  @relation("BpCreatedBy")
  estimatesCreated        Estimate[]         @relation("EstimateCreatedBy")
  priceListEntriesCreated PriceListEntry[]   @relation("PriceListEntryCreatedBy")
  quotesCreated           Quote[]            @relation("QuoteCreatedBy")
  filesUploaded           File[]             @relation("FileUploadedBy")
  auditLogs               AuditLog[]         @relation("AuditLogUser")
  systemSettingsUpdated   SystemSetting[]    @relation("SystemSettingUpdatedBy")
  featureFlagsUpdated     FeatureFlag[]      @relation("FeatureFlagUpdatedBy")
  approvalGroupMembers    ApprovalGroupMember[] @relation("ApprovalGroupMemberUser")
  salesOrdersCreated      SalesOrder[]          @relation("SalesOrderCreatedBy")
  workOrdersCreated       WorkOrder[]           @relation("WorkOrderCreatedBy")
  shippingOrdersCreated   ShippingOrder[]       @relation("ShippingOrderCreatedBy")
  deliveryNotesCreated    DeliveryNote[]        @relation("DeliveryNoteCreatedBy")

  posRequested MaterialPurchaseOrder[] @relation("PoRequestedBy")
  posApproved  MaterialPurchaseOrder[] @relation("PoApprovedBy")
  posOrdered   MaterialPurchaseOrder[] @relation("PoOrderedBy")
  posCompleted MaterialPurchaseOrder[] @relation("PoCompletedBy")
  posCancelled MaterialPurchaseOrder[] @relation("PoCancelledBy")
  posCreated   MaterialPurchaseOrder[] @relation("PoCreatedBy")
  receiptsCreated MaterialReceipt[]    @relation("ReceiptCreatedBy")

  // Employees link to the shared directory by AD objectGUID (stable across
  // username/attribute changes). Null for SYSTEM / GUEST users.
  employee EmployeeDirectory? @relation("UserEmployee", fields: [employeeId], references: [ldapGuid])

  @@map("users")
  @@schema("app")
}

model Role {
  id          Int     @id @default(autoincrement())
  isSystem    Boolean @default(false) @map("is_system")
  rolename    String  @unique
  displayName Json    @map("display_name")
  description Json?

  userAssignments UserRoleRelation[]
  permissions     RolePermissionRelation[]

  @@map("roles")
  @@schema("app")
}

model UserRoleRelation {
  userId       String    @map("user_id") @db.Uuid
  roleId       Int       @map("role_id")
  isActive     Boolean   @default(true) @map("is_active")
  assignedAt   DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  deactivateAt DateTime? @map("deactivate_at") @db.Timestamptz(6)
  assignedBy   String?   @map("assigned_by") @db.Uuid

  user           User  @relation("UserRoles", fields: [userId], references: [id])
  role           Role  @relation(fields: [roleId], references: [id])
  assignedByUser User? @relation("UserRolesAssignedBy", fields: [assignedBy], references: [id])

  @@id([userId, roleId])
  @@map("user_role_relation")
  @@schema("app")
}

model Permission {
  code        String @id
  displayName Json   @map("display_name")
  description Json?

  rolePermissions RolePermissionRelation[]

  @@map("permissions")
  @@schema("app")
}

model RolePermissionRelation {
  roleId         Int    @map("role_id")
  permissionCode String @map("permission_code")
  action         Action
  scope          Scope
  scopeCustom    Int?   @map("scope_custom")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionCode], references: [code])

  @@id([roleId, action, permissionCode])
  @@map("role_permission_relation")
  @@schema("app")
}
