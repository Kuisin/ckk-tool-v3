// 請求 (_specs/tables.md §9): 請求書 / 締日処理。
//
// 請求書 = 番号付き印刷文書 → (year_month, seq) 複合キー（INV-YYYYMM-NNNNN 導出）。
// 明細は出荷書（DISPATCH・SHIPPED）/ 納品書に由来。STOCK_STORAGE は請求フロー外。
// 弥生会計連携（CSV エクスポート）は lib/csv-export.ts。

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID

  @@map("INVOICE_STATUS")
  @@schema("app")
}

enum ClosingStatus {
  PENDING
  PROCESSED
  EXPORTED // 弥生会計エクスポート済み

  @@map("CLOSING_STATUS")
  @@schema("app")
}

model Invoice {
  yearMonth String @map("year_month") @db.Char(6)
  seq       Int

  customerBpId        String   @map("customer_bp_id") @db.Uuid
  customerBranchBpId  String?  @map("customer_branch_bp_id") @db.Uuid
  billingPeriodFrom   DateTime @map("billing_period_from") @db.Date
  billingPeriodTo     DateTime @map("billing_period_to") @db.Date
  subtotal            Decimal  @db.Decimal(12, 2)
  taxAmount           Decimal  @map("tax_amount") @db.Decimal(12, 2)
  totalAmount         Decimal  @map("total_amount") @db.Decimal(12, 2)
  status              InvoiceStatus @default(DRAFT)
  issuedAt            DateTime? @map("issued_at") @db.Timestamptz(6)
  dueDate             DateTime? @map("due_date") @db.Date
  sentAt              DateTime? @map("sent_at") @db.Timestamptz(6)
  pdfFileId           String?   @map("pdf_file_id") @db.Uuid
  yayoiExportedAt     DateTime? @map("yayoi_exported_at") @db.Timestamptz(6)
  notes               String?
  createdBy           String?   @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp       BusinessPartner @relation("InvoiceCustomer", fields: [customerBpId], references: [id])
  customerBranchBp BusinessPartner? @relation("InvoiceCustomerBranch", fields: [customerBranchBpId], references: [id])
  pdfFile          File?            @relation("InvoicePdf", fields: [pdfFileId], references: [id])
  createdByUser    User?            @relation("InvoiceCreatedBy", fields: [createdBy], references: [id])

  items InvoiceItem[]

  @@id([yearMonth, seq])
  @@index([customerBpId])
  @@index([status])
  @@map("invoices")
  @@schema("app")
}

model InvoiceItem {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceYearMonth String @map("invoice_year_month") @db.Char(6)
  invoiceSeq       Int    @map("invoice_seq")

  // 由来（任意）: 出荷書 / 納品書の複合キー
  shippingOrderYearMonth String? @map("shipping_order_year_month") @db.Char(6)
  shippingOrderSeq       Int?    @map("shipping_order_seq")
  deliveryNoteYearMonth  String? @map("delivery_note_year_month") @db.Char(6)
  deliveryNoteSeq        Int?    @map("delivery_note_seq")

  description Json // { ja: '', en: '' }
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  invoice Invoice @relation(fields: [invoiceYearMonth, invoiceSeq], references: [yearMonth, seq], onDelete: Cascade)

  @@index([invoiceYearMonth, invoiceSeq])
  @@map("invoice_items")
  @@schema("app")
}

// 締日処理（顧客×締日で請求書生成の単位を管理）
model BillingClosing {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerBpId String        @map("customer_bp_id") @db.Uuid
  closingDate  DateTime      @map("closing_date") @db.Date
  status       ClosingStatus @default(PENDING)
  totalAmount  Decimal?      @map("total_amount") @db.Decimal(12, 2)
  // 生成した請求書（任意リンク）
  invoiceYearMonth String? @map("invoice_year_month") @db.Char(6)
  invoiceSeq       Int?    @map("invoice_seq")
  processedAt  DateTime? @map("processed_at") @db.Timestamptz(6)
  processedBy  String?   @map("processed_by") @db.Uuid
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  customerBp BusinessPartner @relation("ClosingCustomer", fields: [customerBpId], references: [id])

  @@unique([customerBpId, closingDate])
  @@index([status])
  @@map("billing_closings")
  @@schema("app")
}
