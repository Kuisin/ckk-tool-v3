// 販売 — 試算・価格表・見積書 (_specs/tables.md §1).
//
// フロー: 試算 (原価計算, EST-) → 確定後に価格表登録 → 見積書 (QOT-) は
// 価格表の数量段階から単価を自動解決する。

enum OrderType {
  PRODUCTION
  TEST
  SAMPLE
  OTHER

  @@map("ORDER_TYPE")
  @@schema("sales")
}

enum EstimateStatus {
  DRAFT
  CONFIRMED
  REGISTERED

  @@map("ESTIMATE_STATUS")
  @@schema("sales")
}

enum QuoteStatus {
  DRAFT
  ISSUED
  ACCEPTED
  REJECTED
  EXPIRED

  @@map("QUOTE_STATUS")
  @@schema("sales")
}

// 試算 EST-YYYYMM-NNNNN — 原価計算 → 数量区分別単価。確定後に価格表として登録。
model Estimate {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estimateNumber   String         @unique @map("estimate_number")
  customerBpId     String         @map("customer_bp_id") @db.Uuid
  productId        String         @map("product_id")
  orderType        OrderType      @map("order_type")
  materialId       String?        @map("material_id")
  materialUnitCost Decimal        @default(0) @map("material_unit_cost") @db.Decimal(12, 2)
  machiningMinutes Decimal        @default(0) @map("machining_minutes") @db.Decimal(8, 2)
  machiningRate    Decimal        @default(0) @map("machining_rate") @db.Decimal(12, 2)
  outsourceCost    Decimal        @default(0) @map("outsource_cost") @db.Decimal(12, 2)
  setupCost        Decimal        @default(0) @map("setup_cost") @db.Decimal(12, 2)
  marginRate       Decimal        @default(30) @map("margin_rate") @db.Decimal(5, 2)
  currency         String         @default("JPY")
  status           EstimateStatus @default(DRAFT)
  registeredAt     DateTime?      @map("registered_at") @db.Timestamptz(6)
  notes            String?
  createdBy        String?        @map("created_by") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp    BusinessPartner  @relation("EstimateCustomer", fields: [customerBpId], references: [id])
  product       Product          @relation(fields: [productId], references: [id])
  material      Material?        @relation(fields: [materialId], references: [id])
  createdByUser User?            @relation("EstimateCreatedBy", fields: [createdBy], references: [id])
  tiers         EstimateTier[]
  priceListEntries PriceListEntry[]

  @@map("estimates")
  @@schema("sales")
}

// 数量区分ごとの計算結果 = 価格表候補行。
// 原価/本 = 材料費 + 加工時間/60×レート + 外注費 + 段取り費/min_quantity
// 単価   = 原価 ÷ (1 − 利益率)（手動調整可）
model EstimateTier {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estimateId       String  @map("estimate_id") @db.Uuid
  minQuantity      Int     @map("min_quantity")
  maxQuantity      Int?    @map("max_quantity")
  unitCost         Decimal @map("unit_cost") @db.Decimal(12, 2)
  unitPrice        Decimal @map("unit_price") @db.Decimal(12, 2)
  priceListEntryId String? @map("price_list_entry_id") @db.Uuid
  sortOrder        Int     @default(0) @map("sort_order")

  estimate       Estimate        @relation(fields: [estimateId], references: [id])
  priceListEntry PriceListEntry? @relation(fields: [priceListEntryId], references: [id])

  @@map("estimate_tiers")
  @@schema("sales")
}

// 価格表エントリ: 顧客 + 製品 + 注文種別 = 1 エントリ（作成後不変の識別キー）。
// 有効期間・通貨・状態をエントリ単位で管理し、数量段階は price_list_tiers に分離。
model PriceListEntry {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerBpId String    @map("customer_bp_id") @db.Uuid
  productId    String    @map("product_id")
  orderType    OrderType @map("order_type")
  currency     String    @default("JPY")
  validFrom    DateTime  @map("valid_from") @db.Date
  validUntil   DateTime? @map("valid_until") @db.Date
  estimateId   String?   @map("estimate_id") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")
  createdBy    String?   @map("created_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp    BusinessPartner @relation("PriceListEntryCustomer", fields: [customerBpId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  estimate      Estimate?       @relation(fields: [estimateId], references: [id])
  createdByUser User?           @relation("PriceListEntryCreatedBy", fields: [createdBy], references: [id])
  tiers         PriceListTier[]
  estimateTiers EstimateTier[]

  @@unique([customerBpId, productId, orderType])
  @@map("price_list_entries")
  @@schema("sales")
}

// 数量段階: 本数範囲 → 単価。親エントリの有効期間・通貨を共有する。
model PriceListTier {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  priceListEntryId String  @map("price_list_entry_id") @db.Uuid
  minQuantity      Int     @default(1) @map("min_quantity")
  maxQuantity      Int?    @map("max_quantity")
  unitPrice        Decimal @map("unit_price") @db.Decimal(12, 2)
  sortOrder        Int     @default(0) @map("sort_order")

  entry      PriceListEntry @relation(fields: [priceListEntryId], references: [id])
  quoteItems QuoteItem[]

  @@index([priceListEntryId, minQuantity])
  @@map("price_list_tiers")
  @@schema("sales")
}

// 見積書 QOT-YYYYMM-NNNNN
model Quote {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteNumber        String      @unique @map("quote_number")
  customerBpId       String      @map("customer_bp_id") @db.Uuid
  customerBranchBpId String?     @map("customer_branch_bp_id") @db.Uuid
  status             QuoteStatus @default(DRAFT)
  validUntil         DateTime?   @map("valid_until") @db.Date
  notes              String?
  pdfFileId          String?     @map("pdf_file_id") @db.Uuid
  createdBy          String?     @map("created_by") @db.Uuid
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  customerBp       BusinessPartner  @relation("QuoteCustomer", fields: [customerBpId], references: [id])
  customerBranchBp BusinessPartner? @relation("QuoteCustomerBranch", fields: [customerBranchBpId], references: [id])
  pdfFile          File?            @relation("QuotePdf", fields: [pdfFileId], references: [id])
  createdByUser    User?            @relation("QuoteCreatedBy", fields: [createdBy], references: [id])
  items            QuoteItem[]

  @@map("quotes")
  @@schema("sales")
}

model QuoteItem {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId         String    @map("quote_id") @db.Uuid
  productId       String    @map("product_id")
  orderType       OrderType @map("order_type")
  quantity        Int
  unitPrice       Decimal   @map("unit_price") @db.Decimal(12, 2)
  priceListTierId String?   @map("price_list_tier_id") @db.Uuid
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  amount          Decimal   @db.Decimal(12, 2)
  deliveryDate    DateTime? @map("delivery_date") @db.Date
  notes           String?
  sortOrder       Int       @default(0) @map("sort_order")

  quote         Quote          @relation(fields: [quoteId], references: [id])
  product       Product        @relation(fields: [productId], references: [id])
  priceListTier PriceListTier? @relation(fields: [priceListTierId], references: [id])

  @@map("quote_items")
  @@schema("sales")
}
